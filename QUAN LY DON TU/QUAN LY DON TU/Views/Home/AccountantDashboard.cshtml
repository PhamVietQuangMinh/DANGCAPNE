                            <div class="finance-caption">Tuổi nợ: @invoice.AgingDays ngày</div>
                            @if (invoice.OverCreditLimit)
                            {
                                <div class="finance-caption text-danger">Vượt hạn mức tín dụng</div>
                            }
                        </article>
                    }
                }
                else
                {
                    <div class="empty-state" style="padding:10px 0;">
                        <i class="bi bi-journal-check"></i>
                        <h3>Không có công nợ nào đến hạn sớm</h3>
