@model DANGCAPNE.ViewModels.ApprovalListViewModel
@{
    ViewData["Title"] = "Phe duyet don";
}
<div class="page-content">
    <div class="d-flex justify-between align-center mb-24" style="flex-wrap:wrap;gap:16px">
        <div>
            <h2 style="font-size:24px;font-weight:800;margin-bottom:4px">Phe duyet don tu</h2>
            <p class="text-muted">Ban co <strong class="text-warning">@Model.TotalPending</strong> don dang cho xu ly</p>
        </div>
        <div class="d-flex gap-8">
            <a href="@Url.Action("Kanban")" class="btn btn-outline"><i class="bi bi-kanban"></i> Dạng Kanban</a>
            @if (Model.PendingApprovals.Any())
            {
                <button class="btn btn-success" onclick="showBulkModal()"><i class="bi bi-check2-all"></i> Duyet hang loat</button>
            }
        </div>
    </div>

    @if (Model.PendingApprovals.Any())
    {
        <div class="glass-card mb-16">
            <div class="card-header"><h3><i class="bi bi-funnel text-primary"></i> Bộ lọc nâng cao</h3></div>
            <div class="card-body">
                <div class="form-row" style="gap:12px;flex-wrap:wrap">
                    <div class="col" style="min-width:180px">
                        <label class="form-label">Tìm nhanh</label>
                        <input type="text" id="filterKeyword" class="form-control" placeholder="Mã đơn / người gửi / tiêu đề" oninput="applyApprovalFilters()" />
                    </div>
                    <div class="col" style="min-width:180px">
                        <label class="form-label">Loại đơn</label>
                        <select id="filterFormType" class="form-control" onchange="applyApprovalFilters()">
                            <option value="">-- Tất cả --</option>
                            @foreach (var name in Model.PendingApprovals.Select(a => a.Request?.FormTemplate?.Name).Where(n => !string.IsNullOrEmpty(n)).Distinct())
                            {
                                <option value="@name">@name</option>
                            }
                        </select>
                    </div>
                    <div class="col" style="min-width:160px">
                        <label class="form-label">Từ ngày</label>
                        <input type="date" id="filterFrom" class="form-control" onchange="applyApprovalFilters()" />
                    </div>
                    <div class="col" style="min-width:160px">
                        <label class="form-label">Đến ngày</label>
                        <input type="date" id="filterTo" class="form-control" onchange="applyApprovalFilters()" />
                    </div>
                    <div class="col" style="min-width:160px">
                        <label class="form-label">Nguồn</label>
                        <select id="filterSource" class="form-control" onchange="applyApprovalFilters()">
                            <option value="">-- Tất cả --</option>
                            <option value="direct">Của tôi</option>
                            <option value="delegated">Duyệt thay</option>
                        </select>
                    </div>
                    <div class="col" style="min-width:100px;display:flex;align-items:flex-end">
                        <button type="button" class="btn btn-outline btn-sm" onclick="resetApprovalFilters()"><i class="bi bi-arrow-counterclockwise"></i> Xoá lọc</button>
                    </div>
                </div>
                <div class="d-flex gap-8 align-center mt-8" style="flex-wrap:wrap">
                    <span class="text-muted" style="font-size:12px">Lọc nhanh:</span>
                    <button type="button" class="btn btn-outline btn-sm" onclick="savePresetFilter()"><i class="bi bi-bookmark"></i> Lưu bộ lọc</button>
                    <button type="button" class="btn btn-outline btn-sm" onclick="loadPresetFilter()"><i class="bi bi-bookmark-check"></i> Áp bộ lọc đã lưu</button>
                    <span class="text-muted" style="font-size:12px" id="filterSummary"></span>
                </div>
            </div>
        </div>
        <div class="glass-card mb-24">
            <div class="card-header"><h3><i class="bi bi-clock-fill text-warning"></i> Dang cho duyet (@Model.PendingApprovals.Count)</h3></div>
            <div class="card-body" style="padding:0">
                <form method="post" asp-action="BulkApproval" id="bulkForm">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th><input type="checkbox" id="selectAll" onchange="toggleAll(this)" /></th>
                                <th>Ma don</th>
                                <th>Loai</th>
                                <th>Nguoi gui</th>
                                <th>Tieu de</th>
                                <th>Buoc</th>
                                <th>Ngay gui</th>
                                <th>Thao tac</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var approval in Model.PendingApprovals)
                            {
                                var isDelegated = Model.DelegatedApprovalIds.Contains(approval.Id);
                                <tr class="approval-row"
                                    data-form="@approval.Request?.FormTemplate?.Name"
                                    data-requester="@approval.Request?.Requester?.FullName"
                                    data-code="@approval.Request?.RequestCode"
                                    data-title="@approval.Request?.Title"
                                    data-date="@(approval.Request?.CreatedAt.ToString("yyyy-MM-dd"))"
                                    data-source="@(isDelegated ? "delegated" : "direct")">
                                    <td><input type="checkbox" name="ApprovalIds" value="@approval.Id" class="bulk-check" /></td>
                                    <td><strong class="text-primary">@approval.Request?.RequestCode</strong></td>
                                    <td><i class="bi @approval.Request?.FormTemplate?.Icon" style="color:@approval.Request?.FormTemplate?.IconColor"></i> @approval.Request?.FormTemplate?.Name</td>
                                    <td>@approval.Request?.Requester?.FullName</td>
                                    <td>@approval.Request?.Title</td>
                                    <td>
                                        <span class="status-badge pending">@approval.StepName</span>
                                        @if (isDelegated)
                                        {
                                            <div class="text-muted" style="font-size:11px;margin-top:4px">
                                                <i class="bi bi-person-check"></i> Duyệt thay: @Model.DelegatedFromNames[approval.Id]
                                            </div>
                                        }
                                    </td>
                                    <td class="text-muted">@approval.Request?.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <a href="@Url.Action("Detail", "Requests", new { id = approval.RequestId })" class="btn btn-outline btn-sm"><i class="bi bi-eye"></i> Xem</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div id="bulkActions" style="display:none;padding:20px;border-top:1px solid var(--border-glass)">
                        <div class="d-flex gap-8 align-center flex-wrap">
                            <span class="text-muted">Da chon <strong id="selectedCount">0</strong></span>
                            <input type="text" name="Comments" class="form-control" placeholder="Nhan xet (tuy chon)" style="max-width:300px" />
                            <button type="submit" name="Action" value="Approve" class="btn btn-success btn-sm"><i class="bi bi-check-lg"></i> Duyet tat ca</button>
                            <button type="submit" name="Action" value="Reject" class="btn btn-danger btn-sm"><i class="bi bi-x-lg"></i> Tu choi tat ca</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }

    @if (Model.ProcessedApprovals.Any())
    {
        <div class="glass-card">
            <div class="card-header"><h3><i class="bi bi-check-circle text-success"></i> Da xu ly</h3></div>
            <div class="card-body" style="padding:0">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Ma don</th>
                            <th>Loai</th>
                            <th>Nguoi gui</th>
                            <th>Trang thai</th>
                            <th>Nhan xet</th>
                            <th>Ngay xu ly</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var approval in Model.ProcessedApprovals.Take(20))
                        {
                            var statusCss = approval.Status.ToLower();
                            var statusText = approval.Status switch
                            {
                                "Approved" => "Da duyet",
                                "Rejected" => "Tu choi",
                                "Skipped" => "Bo qua",
                                _ => approval.Status
                            };

                            <tr onclick="location.href='@Url.Action("Detail", "Requests", new { id = approval.RequestId })'" style="cursor:pointer">
                                <td><strong class="text-primary">@approval.Request?.RequestCode</strong></td>
                                <td>@approval.Request?.FormTemplate?.Name</td>
                                <td>
                                    @approval.Request?.Requester?.FullName
                                    @if (approval.ApproverId.HasValue && Model.DelegatedFromNames.ContainsKey(approval.Id))
                                    {
                                        <div class="text-muted" style="font-size:11px;margin-top:4px">
                                            <i class="bi bi-person-check"></i> Duyệt thay: @Model.DelegatedFromNames[approval.Id]
                                        </div>
                                    }
                                </td>
                                <td><span class="status-badge @statusCss">@statusText</span></td>
                                <td class="text-muted">@(approval.Comments?.Length > 40 ? approval.Comments.Substring(0, 40) + "..." : approval.Comments ?? "-")</td>
                                <td class="text-muted">@approval.ActionDate?.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    function toggleAll(el) {
        document.querySelectorAll('.bulk-check').forEach(cb => cb.checked = el.checked);
        updateBulkUI();
    }

    document.addEventListener('change', function (e) {
        if (e.target.classList.contains('bulk-check')) updateBulkUI();
    });

    function updateBulkUI() {
        const checked = document.querySelectorAll('.bulk-check:checked').length;
        const bar = document.getElementById('bulkActions');
        if (bar) bar.style.display = checked > 0 ? 'block' : 'none';
        const cnt = document.getElementById('selectedCount');
        if (cnt) cnt.textContent = checked;
    }

    function showBulkModal() {
        document.querySelectorAll('.bulk-check').forEach(cb => cb.checked = true);
        updateBulkUI();
        window.scrollTo({ top: document.getElementById('bulkForm').offsetTop, behavior: 'smooth' });
    }

    function applyApprovalFilters() {
        const kw = (document.getElementById('filterKeyword')?.value || '').trim().toLowerCase();
        const formType = document.getElementById('filterFormType')?.value || '';
        const from = document.getElementById('filterFrom')?.value || '';
        const to = document.getElementById('filterTo')?.value || '';
        const source = document.getElementById('filterSource')?.value || '';
        let visible = 0;
        document.querySelectorAll('.approval-row').forEach(row => {
            const matchesKw = !kw || ['code','requester','title','form'].some(k =>
                (row.dataset[k] || '').toLowerCase().includes(kw));
            const matchesForm = !formType || row.dataset.form === formType;
            const date = row.dataset.date || '';
            const matchesFrom = !from || date >= from;
            const matchesTo = !to || date <= to;
            const matchesSource = !source || row.dataset.source === source;
            const show = matchesKw && matchesForm && matchesFrom && matchesTo && matchesSource;
            row.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        const sum = document.getElementById('filterSummary');
        if (sum) sum.textContent = `Hiển thị ${visible} dòng`;
    }

    function resetApprovalFilters() {
        ['filterKeyword','filterFormType','filterFrom','filterTo','filterSource'].forEach(id => {
            const el = document.getElementById(id); if (el) el.value = '';
        });
        applyApprovalFilters();
    }

    function savePresetFilter() {
        const preset = {
            kw: document.getElementById('filterKeyword')?.value || '',
            form: document.getElementById('filterFormType')?.value || '',
            from: document.getElementById('filterFrom')?.value || '',
            to: document.getElementById('filterTo')?.value || '',
            source: document.getElementById('filterSource')?.value || ''
        };
        localStorage.setItem('approvalFilterPreset', JSON.stringify(preset));
        alert('Đã lưu bộ lọc vào thiết bị này.');
    }

    function loadPresetFilter() {
        const raw = localStorage.getItem('approvalFilterPreset');
        if (!raw) { alert('Chưa có bộ lọc nào được lưu.'); return; }
        const p = JSON.parse(raw);
        const set = (id, v) => { const el = document.getElementById(id); if (el) el.value = v || ''; };
        set('filterKeyword', p.kw); set('filterFormType', p.form);
        set('filterFrom', p.from); set('filterTo', p.to); set('filterSource', p.source);
        applyApprovalFilters();
    }
</script>
}

<style>
    .data-table th, .data-table td {
        text-align: left !important;
        padding: 12px 16px !important;
        vertical-align: middle;
    }

    .data-table th {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 700;
        color: var(--text-muted);
        border-bottom: 1px solid var(--border-glass);
    }

    .data-table tr:hover {
        background: rgba(92, 103, 242, 0.03);
    }

    .sla-stack {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .sla-time {
        font-size: 11px;
        color: var(--text-muted);
        white-space: nowrap;
    }

    .sla-time.overdue {
        color: #dc2626;
        font-weight: 700;
    }
</style>
