<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"]) - DANGCAPNE</title>
    <meta name="description" content="Hệ thống quản lý đơn từ và phê duyệt doanh nghiệp DANGCAPNE" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if (Context.Session.GetInt32("UserId") != null)
    {
        <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
        <nav class="sidebar" id="sidebar">
            <div class="sidebar-brand">
                <img src="~/img/unnamed.jpg" style="width:40px; height:40px; border-radius:var(--radius-md); object-fit:cover; flex-shrink:0; box-shadow:var(--shadow-sm);" alt="Logo" />
                <div>
                    <h1 style="font-size:16px; text-transform:uppercase; margin:0; line-height:1.2;">Approval<small style="display:block; font-size:11px; text-transform:none; color:var(--text-muted); font-weight:500; margin-top:2px;">Quản trị đơn từ</small></h1>
                </div>
            </div>
            <div class="sidebar-nav">
                @{
                    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                    var roles = (Context.Session.GetString("Roles") ?? "").Split(",", StringSplitOptions.RemoveEmptyEntries);
                    var isAdmin = roles.Contains("Admin");
                    var isHR = roles.Contains("HR");
                    var isManager = roles.Contains("Manager");
                    var isIT = roles.Contains("IT") || roles.Contains("ITManager");
                    var isPrimaryItManagement = string.Equals(Context.Session.GetString("PrimaryRole"), "ITManager", StringComparison.OrdinalIgnoreCase)
                        || string.Equals(Context.Session.GetString("PrimaryRole"), "IT", StringComparison.OrdinalIgnoreCase);
                    var isAccountant = string.Equals(Context.Session.GetString("PrimaryRole"), "Accountant", StringComparison.OrdinalIgnoreCase)
                        || roles.Contains("Accountant")
                        || string.Equals(Context.Session.GetString("Department"), "Phòng Kế toán", StringComparison.OrdinalIgnoreCase);
                    var isEmployeeOnly = !isAdmin && !isHR && !isManager && !isAccountant && !isIT;
                    var canSeeEmployeeExtras = isEmployeeOnly || isIT;
                    var currentAdminTab = Context.Request.Query["tab"].ToString();
                }
                <div class="nav-section">
                    <div class="nav-section-title" data-i18n="TitleDashboard">Tổng quan</div>
                    <a href="@Url.Action("Index", "Home")" class="nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")" data-i18n="NavOverview">
                        <i class="bi bi-grid-1x2-fill"></i> Tổng quan
                    </a>
                    <a href="@Url.Action("Index", "Notifications")" class="nav-link @(currentController == "Notifications" ? "active" : "")" data-i18n="NavNotif">
                        <i class="bi bi-bell-fill"></i> Thông báo
                        <span class="badge-count" id="sidebarNotifCount" style="display:none"></span>
                    </a>
                </div>
                @if (!isAccountant)
                {
                    <div class="nav-section">
                        <div class="nav-section-title" data-i18n="NavEmp">Nhân viên</div>
                        <a href="@Url.Action("EmployeeRequests", "Home")" class="nav-link @(currentAction == "EmployeeRequests" ? "active" : "")" data-i18n="NavEmpRequests">
                            <i class="bi bi-clipboard-check"></i> Quản lý đơn từ
                        </a>
                        @if (canSeeEmployeeExtras)
                        {
                            <a href="@Url.Action("Timeline", "Attendance")" class="nav-link @(currentController == "Attendance" && currentAction == "Timeline" ? "active" : "")" data-i18n="NavEmpTimeline">
                                <i class="bi bi-clock-history"></i> Timeline check out
                            </a>
                            <a href="@Url.Action("Index", "Shift")" class="nav-link @(currentController == "Shift" && currentAction == "Index" ? "active" : "")" data-i18n="NavEmpSchedule">
                                <i class="bi bi-calendar3"></i> Lịch biểu & ca làm
                            </a>
                        }
                        <a href="@Url.Action("Index", "Attendance")" class="nav-link @(currentController == "Attendance" && currentAction == "Index" ? "active" : "")" data-i18n="NavEmpAttendance">
                            <i class="bi bi-clock-fill"></i> Check out
                        </a>
                    </div>
                }
                @if (isAccountant)
                {
                    <div class="nav-section">
                        <div class="nav-section-title">Kế toán</div>
                        <a href="@Url.Action("Index", "Home")" class="nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")">
                            <i class="bi bi-cash-stack"></i> Dashboard kế toán
                        </a>
                        <a href="@Url.Action("Index", "Approvals")" class="nav-link @(currentController == "Approvals" && currentAction == "Index" ? "active" : "")">
                            <i class="bi bi-wallet2"></i> Duyệt nghiệp vụ lương
                        </a>
                        <a href="@Url.Action("PayrollRecords", "Home")" class="nav-link @(currentController == "Home" && currentAction == "PayrollRecords" ? "active" : "")">
                            <i class="bi bi-receipt-cutoff"></i> Hồ sơ lương
                        </a>
                        <a href="@Url.Action("Index", "Requests")" class="nav-link @(currentController == "Requests" && currentAction == "Index" ? "active" : "")">
                            <i class="bi bi-folder2-open"></i> Đơn từ tài chính
                        </a>
                    </div>
                }
                @if (!isAccountant)
                {
                    <div class="nav-section">
                        <div class="nav-section-title" data-i18n="NavRequests">Đơn từ</div>
                        <a href="@Url.Action("SelectTemplate", "Requests")" class="nav-link @(currentAction == "SelectTemplate" ? "active" : "")" data-i18n="NavCreate">
                            <i class="bi bi-plus-circle-fill"></i> Tạo đơn mới
                        </a>
                        <a href="@Url.Action("Index", "Requests")" class="nav-link @(currentController == "Requests" && currentAction == "Index" ? "active" : "")" data-i18n="NavMyReq">
                            <i class="bi bi-file-earmark-text-fill"></i> Đơn từ hệ thống
                        </a>
                    </div>
                }
                @if ((isManager || isAdmin || isHR) && !isAccountant)
                {
                    <div class="nav-section">
                        <div class="nav-section-title" data-i18n="NavApproval">Phê duyệt</div>
                        <a href="@Url.Action("Index", "Approvals")" class="nav-link @(currentController == "Approvals" && currentAction == "Index" ? "active" : "")" data-i18n="NavApproval">
                            <i class="bi bi-check2-circle"></i> Duyệt đơn
                            <span class="badge-count" id="sidebarApprovalCount" style="display:none"></span>
                        </a>
                        @if (isAdmin)
                        {
                        <a href="@Url.Action("Index", "Admin", new { tab = "requeststats" })" class="nav-link @(currentController == "Admin" && currentAction == "Index" && currentAdminTab == "requeststats" ? "active" : "")">
                            <i class="bi bi-bar-chart-line-fill"></i> Thống kê đơn từ
                        </a>
                        }
                    </div>
                }
                @if (isHR || isAdmin)
                {
                    <div class="nav-section">
                        <div class="nav-section-title" data-i18n="NavHR">Nhân sự</div>
                        <a href="@Url.Action("Index", "HR")" class="nav-link @(currentController == "HR" && currentAction == "Index" ? "active" : "")" data-i18n="NavHRKanban">
                            <i class="bi bi-kanban-fill"></i> Bảng Kanban
                        </a>
                        <a href="@Url.Action("LeaveManagement", "HR")" class="nav-link @(currentAction == "LeaveManagement" ? "active" : "")" data-i18n="NavLeave">
                            <i class="bi bi-calendar2-week-fill"></i> Quản lý phép
                        </a>
                        <a href="@Url.Action("Index", "Attendance")" class="nav-link @(currentController == "Attendance" && currentAction == "Index" ? "active" : "")" data-i18n="NavTime">
                            <i class="bi bi-clock-fill"></i> Check out
                        </a>
                        <a href="@Url.Action("AdminReport", "Attendance")" class="nav-link @(currentController == "Attendance" && currentAction == "AdminReport" ? "active" : "")">
                            <i class="bi bi-table"></i> Bảng check out
                        </a>
                    </div>
                }
                @if (isAdmin || isHR || isManager || isIT)
                {
                    <div class="nav-section">
                        <div class="nav-section-title" data-i18n="NavModules">Phân hệ</div>
                        <a href="@Url.Action("Index", "Modules")" class="nav-link @(currentController == "Modules" && currentAction == "Index" ? "active" : "")" data-i18n="NavModules">
                            <i class="bi bi-grid-3x3-gap-fill"></i> Phân hệ mở rộng
                        </a>
                    </div>
                }
                @if (isAdmin)
                {
                    <div class="nav-section">
                        <div class="nav-section-title" data-i18n="NavAdmin">Quản trị</div>
                        <a href="@Url.Action("Delegation", "Admin")" class="nav-link @(currentAction == "Delegation" ? "active" : "")" data-i18n="NavDelegate">
                            <i class="bi bi-arrow-left-right"></i> Ủy quyền
                        </a>
                        <a href="@Url.Action("AuditLogs", "Admin")" class="nav-link @(currentAction == "AuditLogs" ? "active" : "")" data-i18n="NavAudit">
                            <i class="bi bi-shield-lock-fill"></i> Nhật ký hệ thống
                        </a>
                    </div>
                }
                
                @if (isAdmin || isHR || isManager || isIT)
                {
                    <div class="nav-section">
                        @if (isPrimaryItManagement)
                        {
                            <div class="nav-section-title">IT vận hành</div>
                        }
                        else if (isHR || isManager)
                        {
                            <div class="nav-section-title">Phê duyệt</div>
                        }
                        <a href="@Url.Action("Whitelist", "Admin")" class="nav-link @(currentAction == "Whitelist" ? "active" : "")">
                            <i class="bi bi-shield-check"></i> @(isIT ? "Cấp mã nhân viên" : "Phê duyệt Email")
                        </a>
                        @if (isIT)
                        {
                            <a href="@Url.Action("Index", "Admin", new { tab = "users" })" class="nav-link @(currentController == "Admin" && currentAction == "Index" && currentAdminTab != "timekeeping" && currentAdminTab != "requeststats" ? "active" : "")">
                                <i class="bi bi-people-fill"></i> Hồ sơ truy cập nhân viên
                            </a>
                            <a href="@Url.Action("AllowedIPs", "IT")" class="nav-link @(currentController == "IT" && currentAction == "AllowedIPs" ? "active" : "")">
                                <i class="bi bi-hdd-network-fill"></i> Quản lý Wifi công ty
                            </a>
                        }
                        else
                        {
                            <a href="@Url.Action("Index", "Admin", new { tab = "users" })" class="nav-link @(currentController == "Admin" && currentAction == "Index" && currentAdminTab != "timekeeping" && currentAdminTab != "requeststats" ? "active" : "")" data-i18n="NavUsers">
                                <i class="bi bi-people-fill"></i> Quản lý nhân viên
                            </a>
                        }
                        @if (isAdmin || isHR)
                        {
                            <a href="@Url.Action("Index", "Admin", new { tab = "timekeeping" })" class="nav-link @(currentController == "Admin" && currentAction == "Index" && currentAdminTab == "timekeeping" ? "active" : "")">
                                <i class="bi bi-calendar-check"></i> Quản lý check out
                            </a>
                        }
                    </div>
                }

            </div>
            <div class="sidebar-footer">
                <a href="@Url.Action("Profile", "Account")" class="user-card">
                    <div class="user-avatar">
                        @if (!string.IsNullOrEmpty(Context.Session.GetString("Avatar")))
                        {
                            <img src="@Context.Session.GetString("Avatar")" style="width:100%; height:100%; object-fit: cover; border-radius: 50%;" />
                        }
                        else
                        {
                            @(Context.Session.GetString("FullName")?.Substring(0, 1) ?? "U")
                        }
                    </div>
                    <div class="user-info">
                        <div class="user-name">@Context.Session.GetString("FullName")</div>
                        <div class="user-role">@Context.Session.GetString("PrimaryRole") · @Context.Session.GetString("Department")</div>
                    </div>
                </a>
            </div>
        </nav>

        <div class="main-content">
            <header class="top-header">
                <div class="d-flex align-center gap-16">
                    <button class="mobile-toggle" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
                    <h2 class="page-title">
                        @if(ViewData["TitleI18n"] != null) {
                            <span data-i18n="@ViewData["TitleI18n"]">@ViewData["Title"]</span>
                            if(ViewData["TitleSuffix"] != null) {
                                <span> @ViewData["TitleSuffix"]</span>
                            }
                        } else {
                            @ViewData["Title"]
                        }
                    </h2>
                </div>
                <div class="header-actions">
                    <button class="header-btn" onclick="toggleLanguage()" title="Ngôn ngữ / Language">
                        <i class="bi bi-translate"></i>
                        <span id="langDisplay" style="font-size:11px; font-weight:bold; margin-left:4px;">VI</span>
                    </button>
                    <div style="position:relative">
                        <button class="header-btn" onclick="toggleNotifications()" id="notifBell">
                            <i class="bi bi-bell"></i>
                            <span class="notif-badge" id="notifBadge" style="display:none">0</span>
                        </button>
                        <div class="notif-dropdown" id="notifDropdown">
                            <div class="notif-header">
                                <h3><i class="bi bi-bell-fill"></i> <span data-i18n="NavNotif">Thông báo</span></h3>
                                <button class="btn btn-ghost btn-sm" onclick="markAllRead()" data-i18n="MarkAllRead">Đánh dấu tất cả đã đọc</button>
                            </div>
                            <div id="notifList"></div>
                            <a href="@Url.Action("Index", "Notifications")" class="notif-footer" data-i18n="ViewAllNotif">
                                Xem tất cả thông báo
                            </a>
                        </div>
                    </div>
                    <a href="@Url.Action("Profile", "Account")" class="header-btn" style="padding:0; overflow:hidden;">
                        @if (!string.IsNullOrEmpty(Context.Session.GetString("Avatar")))
                        {
                            <img src="@Context.Session.GetString("Avatar")" style="width:32px; height:32px; object-fit: cover; border-radius: 50%;" />
                        }
                        else
                        {
                            <i class="bi bi-person"></i>
                        }
                    </a>
                    <a href="@Url.Action("Logout", "Account")" class="header-btn" title="Đăng xuất"><i class="bi bi-box-arrow-right"></i></a>
                </div>
            </header>

            @if (TempData["Success"] != null)
            {
                <script>
                    document.addEventListener('DOMContentLoaded', function () {
                        if (typeof Swal !== 'undefined') {
                            const Toast = Swal.mixin({
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 3000,
                                timerProgressBar: true,
                                customClass: { popup: 'glass-card' },
                                didOpen: (toast) => {
                                    toast.addEventListener('mouseenter', Swal.stopTimer)
                                    toast.addEventListener('mouseleave', Swal.resumeTimer)
                                }
                            });
                            Toast.fire({
                                icon: 'success',
                                title: '@Html.Raw(TempData["Success"])'
                            });
                        }
                    });
                </script>
            }
            @if (TempData["Error"] != null)
            {
                <script>
                    document.addEventListener('DOMContentLoaded', function () {
                        if (typeof Swal !== 'undefined') {
                            const Toast = Swal.mixin({
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 4000,
                                timerProgressBar: true,
                                customClass: { popup: 'glass-card' },
                                didOpen: (toast) => {
                                    toast.addEventListener('mouseenter', Swal.stopTimer)
                                    toast.addEventListener('mouseleave', Swal.resumeTimer)
                                }
                            });
                            Toast.fire({
                                icon: 'error',
                                title: '@Html.Raw(TempData["Error"])'
                            });
                        }
                    });
                </script>
            }

            @RenderBody()
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('sidebarOverlay').classList.toggle('show');
        }

        function toggleNotifications() {
            const dd = document.getElementById('notifDropdown');
            dd.classList.toggle('show');
            if (dd.classList.contains('show')) loadNotifications();
        }


