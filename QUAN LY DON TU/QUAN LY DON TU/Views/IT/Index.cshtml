@model DANGCAPNE.ViewModels.ITDashboardViewModel
@{
    ViewData["Title"] = "IT Dashboard";
}
<h1>Quản lý IT</h1>
<div class="row">
    <div class="col-md-6">
        <h3>Nhật ký đăng nhập gần đây</h3>
        <table class="table">
            <thead><tr><th>Thời gian</th><th>User</th><th>Action</th></tr></thead>
            <tbody>
                @foreach (var log in Model.RecentAuthLogs)
                {
                    <tr><td>@log.CreatedAt</td><td>@log.Email</td><td>@log.Action</td></tr>
                }
            </tbody>
        </table>
    </div>
    <div class="col-md-6">
        <h3>Người dùng chờ duyệt</h3>
        <ul>
            @foreach (var user in Model.PendingWhitelist)
            {
                <li>@user.FullName (@user.Email) <a href="/IT/ApproveUser/@user.Id" class="btn btn-sm btn-success">Duyệt</a></li>
            }
        </ul>
    </div>
</div>

