@model DANGCAPNE.ViewModels.SignatureProfileViewModel
@{
    ViewData["Title"] = "Chữ ký điện tử";
}

<div class="page-content">
    <div style="max-width:900px;margin:0 auto">
        <div class="glass-card mb-24">
            <div class="card-header">
                <h3><i class="bi bi-pen text-primary"></i> Chữ ký điện tử</h3>
            </div>
            <div class="card-body">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@err.ErrorMessage</div>
                        }
                    </div>
                }

                <form method="post" enctype="multipart/form-data" asp-action="Signature">
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label class="form-label">Tên hiển thị chữ ký</label>
                        <input class="form-control" name="SignatureName" value="@Model.SignatureName" placeholder="Ví dụ: Nguyễn Văn A" required />
                    </div>

                    <div class="grid-2" style="gap:16px">
                        <div class="glass-card" style="padding:16px">
                            <div class="fw-700 mb-8">Ký trực tiếp trên web</div>
                            <div class="text-muted mb-12" style="font-size:13px">Dùng chuột / cảm ứng để ký. Khi bấm “Lưu”, chữ ký sẽ được chèn vào PDF sau khi duyệt đơn.</div>

                            <div class="signature-pad">
                                <canvas id="sigCanvas" width="640" height="220"></canvas>
                            </div>
                            <input type="hidden" id="SignatureDataUrl" name="SignatureDataUrl" value="" />

                            <div class="d-flex" style="gap:10px; margin-top:12px">
                                <button type="button" class="btn btn-ghost" onclick="clearSig()"><i class="bi bi-eraser"></i> Xóa</button>
                                <button type="button" class="btn btn-secondary" onclick="useAsDataUrl()"><i class="bi bi-check2-circle"></i> Dùng chữ ký này</button>
                            </div>

                            <div class="text-muted mt-8" style="font-size:12px">
                                Gợi ý: ký nét mảnh, nền trắng, để PDF nhìn chuyên nghiệp.
                            </div>
                        </div>

                        <div class="glass-card" style="padding:16px">
                            <div class="fw-700 mb-8">Hoặc tải ảnh chữ ký</div>
                            <div class="text-muted mb-12" style="font-size:13px">Hỗ trợ PNG/JPG (khuyến nghị PNG nền trong suốt).</div>

                            <input class="form-control" type="file" name="signatureFile" accept="image/png,image/jpeg" />

                            <div class="mt-16">
                                <div class="fw-700 mb-8">Chữ ký hiện tại</div>
                                @if (!string.IsNullOrWhiteSpace(Model.ExistingSignatureImageUrl))
                                {
                                    <div class="signature-preview">
                                        <img src="@Model.ExistingSignatureImageUrl" alt="Signature" />
                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted">Chưa có chữ ký.</div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="mt-16">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Lưu chữ ký</button>
                        <a class="btn btn-secondary" href="@Url.Action("HandSign", "Account")"><i class="bi bi-pen"></i> Tự ký bằng tay</a>
                        <a class="btn btn-ghost" href="@Url.Action("Profile", "Account")"><i class="bi bi-arrow-left"></i> Quay lại hồ sơ</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="glass-card">
            <div class="card-header">
                <h3><i class="bi bi-info-circle text-muted"></i> Ghi chú</h3>
            </div>
            <div class="card-body text-muted" style="font-size:13px; line-height:1.6">
                <div>- Đây là chữ ký dạng hình ảnh (không phải ký số bằng chứng thư số).</div>
                <div>- PDF sẽ hiển thị chữ ký của người tạo đơn và tất cả cấp duyệt (nếu có cấu hình chữ ký).</div>
            </div>
        </div>
    </div>
</div>

<style>
    .signature-pad {
        border: 1px dashed rgba(255,255,255,0.35);
        border-radius: 14px;
        background: rgba(255,255,255,0.92);
        padding: 10px;
        overflow: hidden;
    }

    #sigCanvas {
        width: 100%;
        height: 220px;
        display: block;
        touch-action: none;
        border-radius: 10px;
        background: white;
    }

    .signature-preview {
        background: rgba(255,255,255,0.92);
        border-radius: 14px;
        padding: 12px;
        border: 1px solid rgba(0,0,0,0.08);
    }

    .signature-preview img {
        max-width: 100%;
        max-height: 110px;
        display: block;
    }
</style>

@section Scripts {
    <script>
        const canvas = document.getElementById('sigCanvas');
        const ctx = canvas.getContext('2d');

        // HiDPI
        (function resizeForDpi() {
            const ratio = window.devicePixelRatio || 1;
            const rect = canvas.getBoundingClientRect();
            const w = Math.floor(rect.width * ratio);
            const h = Math.floor(rect.height * ratio);
            if (canvas.width !== w || canvas.height !== h) {
                canvas.width = w;
                canvas.height = h;
            }
            ctx.scale(ratio, ratio);
            ctx.lineWidth = 2;
            ctx.lineCap = 'round';
            ctx.strokeStyle = '#111827';
        })();

        let drawing = false;
        let lastX = 0, lastY = 0;
        let hasInk = false;

        function getPos(ev) {
            const rect = canvas.getBoundingClientRect();
            const clientX = ev.touches ? ev.touches[0].clientX : ev.clientX;
            const clientY = ev.touches ? ev.touches[0].clientY : ev.clientY;
            return { x: clientX - rect.left, y: clientY - rect.top };
        }

        function startDraw(ev) {
            drawing = true;
            const p = getPos(ev);
            lastX = p.x; lastY = p.y;
            ev.preventDefault();
        }

        function moveDraw(ev) {
            if (!drawing) return;
            const p = getPos(ev);
            ctx.beginPath();
            ctx.moveTo(lastX, lastY);
            ctx.lineTo(p.x, p.y);
            ctx.stroke();
            lastX = p.x; lastY = p.y;
            hasInk = true;
            ev.preventDefault();
        }

        function endDraw() { drawing = false; }

        canvas.addEventListener('mousedown', startDraw);
        canvas.addEventListener('mousemove', moveDraw);
        window.addEventListener('mouseup', endDraw);
        canvas.addEventListener('touchstart', startDraw, { passive: false });
        canvas.addEventListener('touchmove', moveDraw, { passive: false });
        window.addEventListener('touchend', endDraw);

        window.clearSig = function () {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            document.getElementById('SignatureDataUrl').value = '';
            hasInk = false;
        }

        window.useAsDataUrl = function () {
            if (!hasInk) {
                Swal.fire('Chưa có chữ ký', 'Vui lòng ký vào khung trước.', 'warning');
                return;
            }
            const dataUrl = canvas.toDataURL('image/png');
            document.getElementById('SignatureDataUrl').value = dataUrl;
            Swal.fire('OK', 'Đã chọn chữ ký trong khung. Bấm “Lưu chữ ký” để cập nhật.', 'success');
        }
    </script>
}
