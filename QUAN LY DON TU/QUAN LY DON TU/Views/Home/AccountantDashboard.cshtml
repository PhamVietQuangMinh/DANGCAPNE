                                <td><strong>@(slip.User?.FullName ?? "Không xác định")</strong></td>
                                <td>@slip.MainSalary.ToString("N0")</td>
                                <td>@slip.OvertimeSalary.ToString("N0")</td>
                                <td>@slip.LatePenalty.ToString("N0")</td>
                                <td>@slip.AdvanceDeduction.ToString("N0")</td>
                                <td><strong>@slip.NetSalary.ToString("N0")</strong></td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(slip.PdfPath))
                                    {
                                        <a href="@slip.PdfPath" target="_blank" class="btn btn-outline btn-sm">
                                            <i class="bi bi-download"></i> Mở PDF
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa có</span>
                                    }
                                </td>
                            </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted">Tháng @Model.SelectedPayrollMonth chưa có phiếu lương nào được sinh.</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    }
</div>
