@model List<DANGCAPNE.Models.Timekeeping.Timesheet>
@{
    ViewData["Title"] = "Timeline chấm công";
}

<div class="page-content">
    <div class="glass-card">
        <div class="card-header">
            <h3><i class="bi bi-clock-history text-primary"></i> Timeline chấm công</h3>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-calendar-x"></i>
                    <p>Chưa có lịch sử chấm công.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Ngày</th>
                                <th>Giờ vào</th>
                                <th>Giờ ra</th>
                                <th>Giờ công</th>
                                <th>Trạng thái</th>
                                <th>Nguồn</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Date.ToString("dd/MM/yyyy")</td>
                                    <td>@(item.CheckIn?.ToString("HH:mm") ?? "--:--")</td>
                                    <td>@(item.CheckOut?.ToString("HH:mm") ?? "--:--")</td>
                                    <td>@item.WorkHours.ToString("0.##")h</td>
                                    <td>@item.Status</td>
                                    <td>@item.Source</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
