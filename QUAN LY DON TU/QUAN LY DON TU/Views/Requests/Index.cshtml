@model DANGCAPNE.ViewModels.RequestListViewModel
@{
    ViewData["Title"] = "Đơn từ";
}
<div class="page-content">
    <div class="d-flex justify-between align-center mb-24" style="flex-wrap:wrap;gap:16px">
        <div>
            <h2 style="font-size:24px;font-weight:800;margin-bottom:4px" data-i18n="NavRequests">Quản lý đơn từ</h2>
            <p class="text-muted">Theo dõi và quản lý tất cả đơn từ</p>
        </div>
        <a href="@Url.Action("SelectTemplate")" class="btn btn-primary" data-i18n="NavCreate"><i class="bi bi-plus-circle"></i> Tạo đơn mới</a>
    </div>

    <div class="filter-bar">
        <form method="get" class="d-flex gap-8 flex-wrap" style="flex:1">
            <input type="text" name="search" class="form-control search-input" placeholder="Tìm theo mã đơn, tiêu đề..." value="@Model.SearchQuery" data-i18n="LabelSearch" />
            <input type="date" name="from" class="form-control" value="@(Model.FromDateFilter.HasValue ? Model.FromDateFilter.Value.ToString("yyyy-MM-dd") : "")" />
            <input type="date" name="to" class="form-control" value="@(Model.ToDateFilter.HasValue ? Model.ToDateFilter.Value.ToString("yyyy-MM-dd") : "")" />
            <select name="departmentId" class="form-control">
                <option value="">Tất cả phòng ban</option>
                @foreach (var d in Model.Departments)
                {
                    <option value="@d.Id" selected="@(Model.DepartmentIdFilter == d.Id)">@d.Name</option>
                }
            </select>
            <select name="status" class="form-control">
                <option value="" data-i18n="FilterAllStatus">Tất cả trạng thái</option>
                <option value="Pending" selected="@(Model.StatusFilter == "Pending")" data-i18n="TblPending">Chờ duyệt</option>
                <option value="InProgress" selected="@(Model.StatusFilter == "InProgress")" data-i18n="TblInProgress">Đang xử lý</option>
                <option value="Approved" selected="@(Model.StatusFilter == "Approved")" data-i18n="TblApproved">Đã duyệt</option>
                <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")" data-i18n="TblRejected">Từ chối</option>
                <option value="Cancelled" selected="@(Model.StatusFilter == "Cancelled")" data-i18n="TblCancelled">Đã hủy</option>
            </select>
            <select name="priority" class="form-control">
                <option value="">Tất cả ưu tiên</option>
                <option value="Low" selected="@(Model.PriorityFilter == "Low")">Low</option>
                <option value="Normal" selected="@(Model.PriorityFilter == "Normal")">Normal</option>
                <option value="High" selected="@(Model.PriorityFilter == "High")">High</option>
                <option value="Urgent" selected="@(Model.PriorityFilter == "Urgent")">Urgent</option>
            </select>
            <select name="type" class="form-control">
                <option value="" data-i18n="FilterType">Tất cả loại đơn</option>
                @foreach (var ft in Model.FormTemplates)
                {
                    <option value="@ft.Category" selected="@(Model.TypeFilter == ft.Category)">@ft.Name</option>
                }
            </select>
            <button type="submit" class="btn btn-outline"><i class="bi bi-funnel"></i> Lọc</button>
        </form>
    </div>

    <div class="glass-card request-list-shell">
        <div class="card-body request-list-body" style="padding:0">
            @if (Model.Requests.Any())
            {
                <div class="table-wrap request-list-table-wrap">
                <table class="data-table request-list-table">
                    <thead>
                        <tr>
                            <th data-i18n="ColReqCode">Mã đơn</th>
                            <th data-i18n="ColTitle">Tiêu đề</th>
                            <th data-i18n="ColType">Loại</th>
                            <th data-i18n="ColRequester">Người tạo</th>
                            <th data-i18n="ColStatus">Trạng thái</th>
                            <th data-i18n="LabelPriority">Ưu tiên</th>
                            <th data-i18n="ColDate">Ngày tạo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Requests)
                        {
                            var statusCss = r.Status switch { "Pending" => "pending", "Approved" => "approved", "Rejected" => "rejected", "InProgress" => "in-progress", "Cancelled" => "cancelled", "RequestEdit" => "warning", _ => "draft" };
                            var statusText = r.Status switch { "Pending" => "Chờ duyệt", "Approved" => "Đã duyệt", "Rejected" => "Từ chối", "InProgress" => "Đang xử lý", "Cancelled" => "Đã hủy", "RequestEdit" => "Yêu cầu sửa", _ => r.Status };
                            var statusI18n = r.Status switch { "Pending" => "TblPending", "Approved" => "TblApproved", "Rejected" => "TblRejected", "InProgress" => "TblInProgress", "Cancelled" => "TblCancelled", _ => "" };
                            var priCss = r.Priority switch { "High" => "high", "Urgent" => "urgent", "Low" => "low", _ => "normal" };
                            <tr onclick="location.href='@Url.Action("Detail", new { id = r.Id })'" style="cursor:pointer">
                                <td data-label="Mã đơn"><strong class="text-primary">@r.RequestCode</strong></td>
                                <td data-label="Tiêu đề">@r.Title</td>
                                <td data-label="Loại"><i class="bi @r.FormTemplate?.Icon" style="color:@r.FormTemplate?.IconColor"></i> @r.FormTemplate?.Name</td>
                                <td data-label="Người tạo">@r.Requester?.FullName</td>
                                <td data-label="Trạng thái"><span class="status-badge @statusCss" data-i18n="@statusI18n">@statusText</span></td>
                                <td data-label="Ưu tiên"><span class="priority-badge @priCss">@r.Priority</span></td>
                                <td data-label="Ngày tạo" class="text-muted">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <h3 data-i18n="DashNoReq">Không có đơn nào</h3>
                    <p data-i18n="MsgNoReqFilters">Chưa có đơn từ nào phù hợp với bộ lọc</p>
                </div>
            }
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="pagination">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <a href="@Url.Action("Index", new { page = i, status = Model.StatusFilter, type = Model.TypeFilter, search = Model.SearchQuery, departmentId = Model.DepartmentIdFilter, from = Model.FromDateFilter, to = Model.ToDateFilter, priority = Model.PriorityFilter })"
                   class="page-link @(i == Model.CurrentPage ? "active" : "")">@i</a>
            }
        </div>
    }
</div>

<style>
    .data-table th, .data-table td {
        text-align: left !important;
        padding: 12px 16px !important;
        vertical-align: middle;
    }
    .data-table th {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 700;
        color: var(--text-muted);
        border-bottom: 1px solid var(--border-glass);
    }
    .data-table tr:hover {
        background: rgba(92, 103, 242, 0.03);
    }
    @@media (max-width: 640px) {
        .request-list-table-wrap {
            overflow: visible;
        }
        .request-list-table {
            min-width: 0;
        }
        .request-list-table thead {
            display: none;
        }
        .request-list-table,
        .request-list-table tbody,
        .request-list-table tr,
        .request-list-table td {
            display: block;
            width: 100%;
        }
        .request-list-table tr {
            padding: 14px 16px;
            border-bottom: 1px solid var(--border-glass);
        }
        .request-list-table td {
            border: 0;
            padding: 0 0 10px 0 !important;
            white-space: normal;
            overflow-wrap: anywhere;
        }
        .request-list-table td:last-child {
            padding-bottom: 0 !important;
        }
        .request-list-table td::before {
            content: attr(data-label);
            display: block;
            margin-bottom: 4px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            color: var(--text-muted);
        }
        .request-list-table .status-badge,
        .request-list-table .priority-badge {
            max-width: 100%;
            white-space: normal;
        }
    }
</style>
