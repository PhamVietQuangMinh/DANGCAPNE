@model DANGCAPNE.ViewModels.RequestDetailViewModel
@{
    ViewData["TitleI18n"] = "DetailTitlePrefix";
    ViewData["TitleSuffix"] = Model.Request?.RequestCode;
    ViewData["Title"] = "Chi tiết đơn";
    var statusCss = Model.Request?.Status switch { "Pending" => "pending", "Approved" => "approved", "Rejected" => "rejected", "InProgress" => "in-progress", "Cancelled" => "cancelled", _ => "draft" };
    var statusText = Model.Request?.Status switch { "Pending" => "Chờ duyệt", "Approved" => "Đã duyệt", "Rejected" => "Từ chối", "InProgress" => "Đang xử lý", "Cancelled" => "Đã hủy", "RequestEdit" => "Yêu cầu sửa", _ => Model.Request?.Status ?? "" };
}
<style>
    .request-detail-layout > * {
        min-width: 0;
    }
    .request-approval-actions .btn {
        min-width: 0;
    }
    .request-comment-form .form-control {
        flex: 1;
        min-width: 0;
    }
    .sla-inline {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-top: 6px;
    }
    .sla-inline small {
        color: var(--text-muted);
        font-size: 11px;
    }
    @@media (max-width: 640px) {
        .request-approval-actions,
        .request-comment-form {
            flex-direction: column;
            align-items: stretch;
        }
        .request-approval-actions .btn,
        .request-comment-form .btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>
<div class="page-content">
    <div class="content-grid-sidebar request-detail-layout">
        <div>
            <div class="glass-card mb-24">
                <div class="card-header">
                    <h3><i class="bi @Model.Request?.FormTemplate?.Icon" style="color:@Model.Request?.FormTemplate?.IconColor"></i> @Model.Request?.FormTemplate?.Name</h3>
                    <span class="status-badge @statusCss" style="font-size:14px" data-i18n="@(Model.Request?.Status switch { "Pending" => "TblPending", "Approved" => "TblApproved", "Rejected" => "TblRejected", "InProgress" => "TblInProgress", "Cancelled" => "TblCancelled", _ => "" })">@statusText</span>
                </div>
                <div class="card-body">
                    <div class="info-grid-2" style="margin-bottom:24px">
                        <div><span class="text-muted" style="font-size:12px" data-i18n="ColReqCode">Mã đơn</span><br><strong class="text-primary">@Model.Request?.RequestCode</strong></div>
                        <div><span class="text-muted" style="font-size:12px" data-i18n="ColRequester">Người tạo</span><br><strong>@Model.Request?.Requester?.FullName</strong></div>
                        <div><span class="text-muted" style="font-size:12px" data-i18n="ColDept">Phòng ban</span><br><strong>@Model.Request?.Requester?.Department?.Name</strong></div>
                        <div><span class="text-muted" style="font-size:12px" data-i18n="ColDate">Ngày tạo</span><br><strong>@Model.Request?.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong></div>
                    </div>
                    <h4 style="font-size:18px;font-weight:700;margin-bottom:16px">@Model.Request?.Title</h4>

                    <div class="meta-box">
                        @foreach (var field in Model.FormFields)
                        {
                            var val = Model.FormData.ContainsKey(field.FieldName) ? Model.FormData[field.FieldName] : "—";
                            if (field.FieldType == "Dropdown" && field.Options.Any())
                            {
                                var opt = field.Options.FirstOrDefault(o => o.Value == val);
                                if (opt != null) val = opt.Label;
                            }
                            <div style="margin-bottom:12px">
                                <span class="text-muted" style="font-size:12px">@field.Label</span>
                                <div style="font-size:14px;font-weight:500">@val</div>
                            </div>
                        }
                    </div>

                    @if (Model.Request?.Attachments?.Any() == true)
                    {
                        <div style="margin-top:16px">
                            <span class="text-muted" style="font-size:12px" data-i18n="CardAttach">File đính kèm</span>
                            @foreach (var att in Model.Request.Attachments)
                            {
                                <div class="attachment-item">
                                    <i class="bi bi-file-earmark text-primary"></i>
                                    <a href="@att.FilePath" target="_blank" style="color:var(--accent-primary);font-size:13px;text-decoration:none">@att.FileName</a>
                                    <span class="text-muted" style="font-size:11px">(@((att.FileSize / 1024.0).ToString("0.#")) KB)</span>
                                </div>
                            }
                        </div>
                    }

                </div>
            </div>

            @if (Model.CanEdit)
            {
                <div class="glass-card mb-24">
                    <div class="card-body">
                        <a href="@Url.Action("Edit", "Requests", new { id = Model.Request?.Id })" class="btn btn-warning" style="width:100%; display:flex; align-items:center; justify-content:center; gap:8px;">
                            <i class="bi bi-pencil-square"></i> <span data-i18n="BtnEditRedo">Sửa đơn & Gửi lại</span>
                        </a>
                    </div>
                </div>
            }

            @if (Model.CanApprove)
            {
                <div class="glass-card mb-24">
                    <div class="card-header"><h3><i class="bi bi-check2-square text-success"></i> <span data-i18n="CardApproveAction">Thao tác phê duyệt</span></h3></div>
                    <div class="card-body">
                        <form method="post" asp-controller="Approvals" asp-action="ProcessApproval">
                            <input type="hidden" name="ApprovalId" value="@Model.CurrentApprovalId" />
                            <input type="hidden" name="RequestId" value="@Model.Request?.Id" />
                            <div class="form-group">
                                <label class="form-label" data-i18n="LabelCommentReason">Nhận xét / Lý do</label>
                                <textarea name="Comments" class="form-control" placeholder="Nhập nhận xét (tùy chọn khi duyệt, bắt buộc khi từ chối)" data-i18n="PlaceholderLongComment"></textarea>
                            </div>
                            @if (Model.RequiresPin)
                            {
                                <div class="form-group">
                                    <label class="form-label"><i class="bi bi-shield-lock text-warning"></i> <span data-i18n="LabelPin">Mã PIN xác thực (bắt buộc cho đơn tài chính)</span></label>
                                    <input type="password" name="Pin" class="form-control" placeholder="Nhập mã PIN 4 số" data-i18n="PlaceholderPin" maxlength="4" style="max-width:200px" />
                                </div>
                            }
                            <div class="inline-actions request-approval-actions">
                                <button type="submit" name="Action" value="Approve" class="btn btn-success"><i class="bi bi-check-lg"></i> <span data-i18n="BtnApprove">Phê duyệt</span></button>
                                <button type="submit" name="Action" value="Reject" class="btn btn-danger"><i class="bi bi-x-lg"></i> <span data-i18n="BtnReject">Từ chối</span></button>
                                <button type="submit" name="Action" value="RequestEdit" class="btn btn-warning"><i class="bi bi-pencil"></i> <span data-i18n="BtnReqEdit">Yêu cầu chỉnh sửa</span></button>
                            </div>
                        </form>
                    </div>
                </div>
            }

            <div class="glass-card mb-24">
                <div class="card-header"><h3><i class="bi bi-chat-dots-fill text-info"></i> <span data-i18n="CardDiscussion">Thảo luận</span> (@Model.Comments.Count)</h3></div>
                <div class="card-body">
                    <div class="comment-list">
                        @foreach (var c in Model.Comments)
                        {
                            <div class="comment-item">
                                <div class="comment-avatar">@c.User?.FullName?.Substring(0, 1)</div>
                                <div class="comment-body">
                                    <div class="comment-header">
                                        <strong>@c.User?.FullName</strong>
                                        <span>@c.CreatedAt.ToString("HH:mm dd/MM/yyyy")</span>
                                    </div>
                                    <div class="comment-content">@c.Content</div>
                                </div>
                            </div>
                        }
                        @if (!Model.Comments.Any())
                        {
                            <p class="text-muted" style="font-size:13px" data-i18n="MsgNoComments">Chưa có bình luận nào.</p>
                        }
                    </div>
                    <form method="post" asp-action="AddComment" class="inline-actions request-comment-form" style="margin-top:16px">
                        <input type="hidden" name="requestId" value="@Model.Request?.Id" />
                        <input type="text" name="content" class="form-control" placeholder="Viết bình luận... (hỗ trợ @@mention)" data-i18n="PlaceholderDiscuss" required />
                        <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-send"></i></button>
                    </form>
                </div>
            </div>
        </div>

        @* ====================== CỘT PHẢI ======================*@
        <div>

            @* ===== LUỒNG DUYỆT =====*@
            @{
                var currentUserId = Context.Session.GetInt32("UserId");
                var userRoles = (Context.Session.GetString("Roles") ?? "").Split(",");
                bool isRequester = false;
            }

            @if (isRequester)
            {
                @* ═══════════ EMPLOYEE VIEW: Zigzag 5-Step Stepper ═══════════ *@
                <div class="glass-card mb-24">
                    <div class="card-header">
                        <h3><i class="bi bi-signpost-split-fill"></i> <span data-i18n="CardFlow">Luồng duyệt</span></h3>
                    </div>
                    <div class="card-body" style="padding:0">
                        <style>
                            .flow-wrap { display:flex; flex-direction:column; padding:20px 20px 24px; }
                            .flow-row { display:flex; align-items:center; width:100%; min-height:52px; position:relative; z-index:2; }
                            .flow-row.left { justify-content:flex-start; }
                            .flow-row.right { justify-content:flex-end; }
                            .flow-node { display:flex; align-items:center; gap:14px; width:230px; max-width:230px; }
                            .flow-row.right .flow-node { flex-direction:row-reverse; text-align:right; }
                            .flow-icon { width:52px; height:52px; border-radius:50%; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:24px; background:var(--bg-glass); border:2px solid rgba(150,150,160,0.2); filter:grayscale(1) opacity(0.5); transition:all 0.4s cubic-bezier(0.4, 0, 0.2, 1); color: #888; z-index:2; position:relative; }
                            .flow-text { padding: 0; box-shadow: none; position: relative; z-index: 2; margin-left: 4px; }
                            .flow-row.right .flow-text { margin-left: 0; margin-right: 4px; }
                            .flow-label { font-size:14px; font-weight:800; line-height:1.4; color:#222; transition:color 0.3s; }
                            .flow-sub { font-size:12px; color:#999; font-weight:500; margin-top:4px; line-height:1.4; }
                            .flow-node.waiting .flow-label { color:#82868b; }

                            .flow-conn { width:100%; height:50px; position:relative; z-index:1; }
                            .flow-conn svg { width:100%; height:100%; display:block; }

                            .fc-line { fill:none; stroke-linecap:round; transition: all 0.5s; }
                            .fc-done { stroke: url(#gradientDone) #28c76f; stroke-width:3; }
                            .fc-pend { stroke:rgba(150,150,160,0.3); stroke-dasharray:6 6; stroke-width:2; }
                            .fc-rej { stroke:#ff4c4c; stroke-width:3; }

                            .flow-node.is-completed .flow-icon, .flow-node.is-skipped .flow-icon { background:linear-gradient(135deg, #28c76f, #48e58f); border:none; filter:none; box-shadow:0 4px 15px rgba(40,199,111,0.4); color:#fff; }
                            .flow-node.is-active .flow-icon { background:linear-gradient(135deg, #ff9800, #ffc107); border:none; filter:none; color:#fff; animation:flowActivePulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
                            .flow-node.is-rejected .flow-icon { background:linear-gradient(135deg, #ea5455, #ff8a8a); border:none; filter:none; color:#fff; box-shadow:0 4px 15px rgba(234,84,85,0.4); }
                            .flow-node.is-final.is-completed .flow-icon { font-size:28px; transform:scale(1.05); }

                            @@keyframes flowActivePulse { 0%{box-shadow:0 0 0 0 rgba(255,152,0,0.6)} 70%{box-shadow:0 0 0 15px rgba(255,152,0,0)} 100%{box-shadow:0 0 0 0 rgba(255,152,0,0)} }
                        </style>
                        <svg width="0" height="0" style="position:absolute;">
                            <defs>
                                <linearGradient id="gradientDone" x1="0%" y1="0%" x2="100%" y2="0%">
                                    <stop offset="0%" stop-color="#28c76f" />
                                    <stop offset="100%" stop-color="#48e58f" />
                                </linearGradient>
                            </defs>
                        </svg>

                        @{
                            var dbSteps2 = Model.ApprovalHistory.OrderBy(a => a.StepOrder).ToList();
                            bool isOk2 = Model.Request?.Status == "Approved";
                            bool hasPend2 = dbSteps2.Any(s => s.Status == "Pending" || s.Status == "RequestEdit");
                            var nodes2 = new List<(string t, string s, string em, string st)>();
                            
                            nodes2.Add(("Gửi thành công", Model.Request?.CreatedAt.ToString("HH:mm dd/MM") ?? "", "<i class=\"bi bi-file-earmark-check\"></i>", "is-completed"));
                            
                            string xemSt2 = "waiting";
                            if (isOk2 || dbSteps2.Any(s => s.Status == "Approved" || s.Status == "Rejected")) xemSt2 = "is-completed";
                            else if (hasPend2) xemSt2 = "is-active";
                            nodes2.Add(("Đang xem xét", "", "<i class=\"bi bi-search\"></i>", xemSt2));
                            
                            var admSteps2 = dbSteps2.Where(s => s.StepName != null && s.StepName.ToLower().Contains("admin")).ToList();
                            var hrSteps2 = dbSteps2.Where(s => !admSteps2.Contains(s)).ToList();
                            
                            string hrSt2 = "waiting", hrSub2 = "";
                            if (hrSteps2.Any()) {
                                hrSub2 = string.Join(", ", hrSteps2.Select(s => s.Approver?.FullName ?? "?"));
                                if (hrSteps2.All(s => s.Status == "Approved" || s.Status == "Skipped")) { 
                                    if (hrSteps2.Any(s => s.Status == "Skipped")) hrSt2 = "is-skipped";
                                    else hrSt2 = "is-completed";
                                }
                                else if (hrSteps2.Any(s => s.Status == "Rejected")) hrSt2 = "is-rejected";
                                else if (hrSteps2.Any(s => s.Status == "Pending" || s.Status == "RequestEdit")) hrSt2 = "is-active";
                            }
                            nodes2.Add(("HR/Trưởng Phòng duyệt", hrSub2, "<i class=\"bi bi-person-check\"></i>", hrSt2));
                            
                            string admSt2 = "waiting", admSub2 = "";
                            if (admSteps2.Any()) {
                                var adm2 = admSteps2.First();
                                admSub2 = adm2.Approver?.FullName ?? "Admin";
                                if (adm2.Status == "Approved") admSt2 = "is-completed";
                                else if (adm2.Status == "Skipped") admSt2 = "is-skipped";
                                else if (adm2.Status == "Rejected") admSt2 = "is-rejected";
                                else if ((adm2.Status == "Pending" || adm2.Status == "RequestEdit") && hrSteps2.All(s => s.Status == "Approved" || s.Status == "Skipped")) admSt2 = "is-active";
                            }
                            nodes2.Add(("Admin duyệt", admSub2, "<i class=\"bi bi-shield-check\"></i>", admSt2));
                            
                            // If request is fully Approved, ensure ALL preceding steps are marked completed visually
                            if (isOk2) {
                                for(int i=0; i<nodes2.Count; i++) {
                                    var n_item = nodes2[i];
                                    if (n_item.st != "is-completed" && n_item.st != "is-completed is-final") {
                                        nodes2[i] = (n_item.t, n_item.s, n_item.em, "is-completed");
                                    }
                                }
                            }

                            nodes2.Add(("Hoàn tất", isOk2 ? "Đơn đã được duyệt" : "", "<i class=\"bi bi-check-circle-fill\"></i>", isOk2 ? "is-completed is-final" : "waiting is-final"));
                        }

                        <div class="flow-wrap">
                            @for (int n = 0; n < nodes2.Count; n++)
                            {
                                var nd2 = nodes2[n]; var side2 = (n % 2 == 0) ? "left" : "right";
                                if (n > 0)
                                {
                                    var pSt2 = nodes2[n - 1].st; var pSide2 = ((n - 1) % 2 == 0) ? "left" : "right";
                                    string lc2 = "fc-pend";
                                    if ((pSt2.Contains("is-completed") || pSt2.Contains("is-skipped")) &&
                                        (nd2.st.Contains("is-completed") || nd2.st.Contains("is-active") || nd2.st.Contains("is-skipped"))) lc2 = "fc-done";
                                    else if (nd2.st.Contains("is-rejected") || pSt2.Contains("is-rejected")) lc2 = "fc-rej";
                                    <div class="flow-conn">
                                        <svg viewBox="0 0 360 50" preserveAspectRatio="none">
                                            @if (pSide2 == "left") { <line class="fc-line @lc2" x1="26" y1="0" x2="334" y2="50" /> }
                                            else { <line class="fc-line @lc2" x1="334" y1="0" x2="26" y2="50" /> }
                                        </svg>
                                    </div>
                                }
                                <div class="flow-row @side2">
                                    <div class="flow-node @nd2.st">
                                        <div class="flow-icon">@Html.Raw(nd2.em)</div>
                                        <div class="flow-text">
                                            <div class="flow-label">@nd2.t</div>
                                            @if (!string.IsNullOrEmpty(nd2.s)) { <div class="flow-sub">@nd2.s</div> }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
            else
            {
                @* ═══════════ APPROVER VIEW: Compact Professional Timeline ═══════════ *@
                <div class="glass-card mb-24">
                    <div class="card-header">
                        <h3><i class="bi bi-diagram-3-fill"></i> <span data-i18n="CardFlow">Tiến trình duyệt</span></h3>
                    </div>
                    <div class="card-body" style="padding:16px 20px;">
                        <style>
                            .atl-wrap { display:flex; flex-direction:column; gap:0; }
                            .atl-item { display:flex; gap:14px; position:relative; padding-bottom:20px; }
                            .atl-item:last-child { padding-bottom:0; }
                            /* Vertical line */
                            .atl-item::before {
                                content:''; position:absolute; left:19px; top:42px; bottom:0;
                                width:2px; background:rgba(150,150,160,0.15);
                            }
                            .atl-item:last-child::before { display:none; }
                            .atl-item.atl-done::before { background:#28c76f; }
                            .atl-item.atl-rej::before { background:#ff4c4c; }
                            /* Avatar */
                            .atl-avatar {
                                width:40px; height:40px; border-radius:50%; flex-shrink:0;
                                display:flex; align-items:center; justify-content:center;
                                font-size:16px; font-weight:700; color:#fff;
                                background:rgba(150,150,160,0.25);
                                z-index:1; position:relative;
                                transition:all 0.3s;
                            }
                            .atl-done .atl-avatar { background:#28c76f; box-shadow:0 2px 8px rgba(40,199,111,0.3); }
                            .atl-skip .atl-avatar { background:#e2e2e9; color:#82868b; }
                            .atl-active .atl-avatar { background:#ffc107; color:#333; box-shadow:0 0 0 4px rgba(255,193,7,0.25); animation:atlPulse 2s infinite; }
                            .atl-rej .atl-avatar { background:#ff4c4c; box-shadow:0 2px 8px rgba(255,76,76,0.3); }
                            .atl-wait .atl-avatar { background:rgba(150,150,160,0.2); color:rgba(150,150,160,0.5); }
                            /* Content */
                            .atl-content { flex:1; min-width:0; }
                            .atl-header { display:flex; align-items:center; justify-content:space-between; gap:8px; }
                            .atl-name { font-size:13px; font-weight:700; color:var(--text-primary); }
                            .atl-badge {
                                font-size:10px; font-weight:700; padding:3px 10px; border-radius:20px;
                                text-transform:uppercase; letter-spacing:0.5px; white-space:nowrap;
                            }
                            .atl-badge.b-approved { background:rgba(40,199,111,0.12); color:#28c76f; }
                            .atl-badge.b-skipped { background:rgba(150,150,160,0.1); color:#82868b; }
                            .atl-badge.b-pending { background:rgba(255,193,7,0.12); color:#e6a600; }
                            .atl-badge.b-rejected { background:rgba(255,76,76,0.12); color:#ff4c4c; }
                            .atl-badge.b-waiting { background:rgba(150,150,160,0.1); color:rgba(150,150,160,0.5); }
                            .atl-badge.b-reqedit { background:rgba(255,152,0,0.12); color:#ff9800; }
                            .atl-role { font-size:11px; color:var(--text-muted); margin-top:2px; }
                            .atl-comment { font-size:11px; color:var(--text-muted); font-style:italic; margin-top:4px; padding:6px 10px; background:rgba(150,150,160,0.06); border-radius:var(--radius-sm); border-left:3px solid rgba(150,150,160,0.2); }
                            .atl-done .atl-comment { border-left-color:#28c76f; }
                            .atl-skip .atl-comment { border-left-color:#cdd1d5; }
                            .atl-rej .atl-comment { border-left-color:#ff4c4c; }
                            .atl-time { font-size:10px; color:var(--text-muted); margin-top:3px; }

                            @@keyframes atlPulse { 0%{box-shadow:0 0 0 0 rgba(255,193,7,0.5)} 70%{box-shadow:0 0 0 10px rgba(255,193,7,0)} 100%{box-shadow:0 0 0 0 rgba(255,193,7,0)} }
                        </style>

                        @{
                            var stepsA = Model.ApprovalHistory.OrderBy(a => a.StepOrder).ToList();
                            int firstPendA = -1;
                            for (int ia = 0; ia < stepsA.Count; ia++) {
                                if ((stepsA[ia].Status == "Pending" || stepsA[ia].Status == "RequestEdit") && firstPendA < 0) firstPendA = ia;
                            }

                            int SlaHoursForStep(DANGCAPNE.Models.Requests.RequestApproval step)
                            {
                                var n = (step.StepName ?? "").ToLowerInvariant();
                                if (n.Contains("hr") || n.Contains("nhân sự")) return 48;
                                if (n.Contains("giám đốc") || n.Contains("director")) return 72;
                                if (n.Contains("kế toán") || n.Contains("accountant")) return 48;
                                return 24; // Trưởng phòng mặc định
                            }
                        }

                        <style>
                            .atl-sla { display:inline-flex; align-items:center; gap:6px; margin-top:6px; padding:4px 10px; border-radius:999px; font-size:12px; font-weight:600; background:rgba(255,193,7,0.15); color:#b7791f; border:1px solid rgba(255,193,7,0.35); }
                            .atl-sla.is-danger { background:rgba(220,53,69,0.12); color:#b02a37; border-color:rgba(220,53,69,0.35); }
                            .atl-sla.is-overdue { background:rgba(220,53,69,0.2); color:#842029; border-color:rgba(220,53,69,0.5); }
                            .atl-sla.is-safe { background:rgba(25,135,84,0.12); color:#0f5132; border-color:rgba(25,135,84,0.35); }
                            .atl-sla i { font-size:13px; }
                        </style>

                        <div class="atl-wrap">
                            @for (int ia = 0; ia < stepsA.Count; ia++)
                            {
                                var sa = stepsA[ia];
                                string itemCls = "atl-wait";
                                string badgeCls = "b-waiting"; string badgeText = "Chờ";
                                string avatarIcon = "⏳";

                                if (sa.Status == "Approved")
                                { itemCls = "atl-done"; badgeCls = "b-approved"; badgeText = "Đã duyệt"; avatarIcon = "✓"; }
                                else if (sa.Status == "Skipped")
                                { itemCls = "atl-done"; badgeCls = "b-approved"; badgeText = "Bỏ qua"; avatarIcon = "✓"; }
                                else if (sa.Status == "Rejected")
                                { itemCls = "atl-rej"; badgeCls = "b-rejected"; badgeText = "Từ chối"; avatarIcon = "✗"; }
                                else if (sa.Status == "RequestEdit")
                                { itemCls = "atl-active"; badgeCls = "b-reqedit"; badgeText = "Yêu cầu sửa"; avatarIcon = "✎"; }
                                else if (ia == firstPendA)
                                { itemCls = "atl-active"; badgeCls = "b-pending"; badgeText = "Đang chờ"; avatarIcon = "⟳"; }


                                var initial = sa.Approver?.FullName?.Length > 0 ? sa.Approver.FullName.Substring(0, 1).ToUpper() : "?";

                                <div class="atl-item @itemCls">
                                    <div class="atl-avatar">
                                        @if (itemCls == "atl-done") { <text>✓</text> }
                                        else if (itemCls == "atl-rej") { <text>✗</text> }
                                        else { @initial }
                                    </div>
                                    <div class="atl-content">
                                        <div class="atl-header">
                                            <span class="atl-name">@(sa.Approver?.FullName ?? "Chưa xác định")</span>
                                            <span class="atl-badge @badgeCls">@badgeText</span>
                                        </div>
                                        <div class="atl-role">@(sa.StepName ?? $"Bước {sa.StepOrder}")</div>
                                        @if (ia == firstPendA && (sa.Status == "Pending" || sa.Status == "RequestEdit") && Model.Request != null)
                                        {
                                            var slaHours = SlaHoursForStep(sa);
                                            DateTime baseTime = Model.Request.CreatedAt;
                                            if (ia > 0 && stepsA[ia - 1].ActionDate.HasValue)
                                            {
                                                baseTime = stepsA[ia - 1].ActionDate!.Value;
                                            }
                                            var deadlineUtc = DateTime.SpecifyKind(baseTime, DateTimeKind.Utc).AddHours(slaHours);
                                            <div class="atl-sla" data-deadline="@deadlineUtc.ToString("o")" data-sla-hours="@slaHours">
                                                <i class="bi bi-stopwatch"></i>
                                                <span class="sla-text">Hạn duyệt: @deadlineUtc.ToLocalTime().ToString("HH:mm dd/MM/yyyy")</span>
                                                <span class="sla-countdown">· đang tính...</span>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(sa.Comments))
                                        {
                                            <div class="atl-comment">"@sa.Comments"</div>
                                        }
                                        @if (sa.ActionDate != null)
                                        {
                                            <div class="atl-time"><i class="bi bi-clock"></i> @sa.ActionDate?.ToString("HH:mm dd/MM/yyyy")</div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
            @* ===== /LUỒNG DUYỆT =====*@
            @if (Model.CanCancel)
            {
                <div class="glass-card mb-24">
                    <div class="card-body">
                        <form method="post" asp-action="Cancel" asp-route-id="@Model.Request?.Id" onsubmit="return confirm(typeof dict !== 'undefined' ? dict[localStorage.getItem('dangcapne_lang') || 'vi']?.ConfirmCancel : 'Bạn có chắc chắn muốn hủy đơn này?');">
                            <button type="submit" class="btn btn-danger" style="width:100%"><i class="bi bi-x-circle"></i> <span data-i18n="BtnCancel">Hủy đơn</span></button>
                        </form>
                    </div>
                </div>
            }

            <div class="glass-card">
                <div class="card-header"><h3><i class="bi bi-clock-history"></i> <span data-i18n="CardHistory">Lịch sử</span></h3></div>
                <div class="card-body" style="padding:12px 20px">
                    @foreach (var log in Model.AuditLogs.Take(10))
                    {
                        var actionText = log.Action switch { "Created" => "Tạo mới", "Approved" => "Phê duyệt", "Rejected" => "Từ chối", "RequestEdit" => "Yêu cầu sửa", "Cancelled" => "Hủy", _ => log.Action };
                        var actionI18n = log.Action switch { "Created" => "ActionCreated", "Approved" => "ActionApproved", "Rejected" => "ActionRejected", "RequestEdit" => "ActionReqEdit", "Cancelled" => "ActionCancelled", _ => "" };
                        var iconCss = log.Action.ToLower() switch { "created" => "created", "approved" => "approved", "rejected" => "rejected", _ => "commented" };
                        <div class="audit-item">
                            <div class="audit-icon @iconCss"><i class="bi bi-@(log.Action == "Created" ? "plus" : log.Action == "Approved" ? "check" : log.Action == "Rejected" ? "x" : "chat")"></i></div>
                            <div style="flex:1">
                                <div style="font-size:13px;font-weight:500">@log.User?.FullName <span class="text-muted" data-i18n="@actionI18n">@actionText</span></div>
                                <div style="font-size:11px;color:var(--text-muted)">@log.CreatedAt.ToString("HH:mm dd/MM/yyyy")</div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="glass-card" style="margin-top:16px">
                <div class="card-header"><h3><i class="bi bi-activity"></i> Timeline</h3></div>
                <div class="card-body" style="padding:12px 20px">
                    @if (Model.Timeline != null && Model.Timeline.Any())
                    {
                        <div class="audit-list">
                            @foreach (var item in Model.Timeline.Take(25))
                            {
                                <div class="audit-item">
                                    <div class="audit-icon comment"><i class="bi bi-dot"></i></div>
                                    <div style="flex:1">
                                        <div style="font-size:13px;font-weight:600">
                                            @item.Title
                                            @if (!string.IsNullOrWhiteSpace(item.ActorName))
                                            {
                                                <span class="text-muted"> · @item.ActorName</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(item.Details))
                                        {
                                            <div style="font-size:12px;color:var(--text-muted)">@item.Details</div>
                                        }
                                        <div style="font-size:11px;color:var(--text-muted)">@item.At.ToString("HH:mm dd/MM/yyyy")</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">Chưa có timeline.</div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<script>
(function(){
    function updateSlaBadges(){
        var nodes = document.querySelectorAll('.atl-sla[data-deadline]');
        if (!nodes.length) return;
        var now = Date.now();
        nodes.forEach(function(el){
            var deadline = new Date(el.getAttribute('data-deadline')).getTime();
            var slaHours = parseFloat(el.getAttribute('data-sla-hours')) || 24;
            var diffMs = deadline - now;
            var cd = el.querySelector('.sla-countdown');
            el.classList.remove('is-safe','is-danger','is-overdue');
            if (diffMs <= 0){
                var overMs = -diffMs;
                var overH = Math.floor(overMs / 3600000);
                var overM = Math.floor((overMs % 3600000) / 60000);
                cd.textContent = '· Quá hạn ' + overH + 'h ' + overM + 'm';
                el.classList.add('is-overdue');
                return;
            }
            var h = Math.floor(diffMs / 3600000);
            var m = Math.floor((diffMs % 3600000) / 60000);
            var s = Math.floor((diffMs % 60000) / 1000);
            cd.textContent = '· Còn ' + h + 'h ' + (m < 10 ? '0'+m : m) + 'm ' + (s < 10 ? '0'+s : s) + 's';
            var ratio = diffMs / (slaHours * 3600000);
            if (ratio < 0.25) el.classList.add('is-danger');
            else if (ratio > 0.5) el.classList.add('is-safe');
        });
    }
    updateSlaBadges();
    setInterval(updateSlaBadges, 1000);
})();
</script>
