            </div>
            <div class="card-body">
                <form method="post" asp-action="CreateInvoiceRecord" asp-controller="Home" class="finance-form-grid">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="payrollMonth" value="@Model.SelectedPayrollMonth" />
                    <div class="content-grid-2">
                        <div>
                            <label>Loại công nợ</label>
                            <select name="invoiceType">
                                <option value="Receivable">Phải thu khách hàng</option>
                                <option value="Payable">Phải trả nhà cung cấp</option>
                            </select>
                        </div>
                        <div>
                            <label>Số hóa đơn</label>
                            <input type="text" name="invoiceNo" />
                        </div>
                    </div>
                    <div class="content-grid-2">
                        <div>
                            <label>Đối tác</label>
                            <input type="text" name="counterpartyName" />
                        </div>
                        <div>
                            <label>Mã số thuế</label>
                            <input type="text" name="taxCode" />
                        </div>
                    </div>
                    <div class="content-grid-2">
                        <div>
                            <label>Ngày hóa đơn</label>
                            <input type="date" name="invoiceDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>
                        <div>
                            <label>Ngày đến hạn</label>
                            <input type="date" name="dueDate" value="@DateTime.Today.AddDays(5).ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                    <div class="content-grid-3">
                        <div>
                            <label>Giá trị hóa đơn</label>
                            <input type="number" name="amount" step="1000" min="0" />
                        </div>
                        <div>
                            <label>Đã thanh toán</label>
                            <input type="number" name="paidAmount" step="1000" min="0" value="0" />
                        </div>
                        <div>
                            <label>Hạn mức tín dụng</label>
                            <input type="number" name="creditLimit" step="1000" min="0" value="0" />
                        </div>
                    </div>
                    <div>
                        <label>Ghi chú</label>
                        <textarea name="notes"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save2"></i> Lưu công nợ</button>
                </form>
            </div>
        </div>

        @if (Model.IsChiefAccountant)
        {
        <div class="glass-card finance-panel stagger-elem">
            <div class="card-header">
                <h3><i class="bi bi-folder2-open text-danger"></i> Kho hóa đơn & chứng từ</h3>
                <span class="finance-caption">Lưu trữ PDF/XML và tra cứu theo số chứng từ, mã số thuế</span>
            </div>
            <div class="card-body">
                <form method="post" asp-action="CreateAccountingDocument" asp-controller="Home" class="finance-form-grid" style="margin-bottom:20px;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="payrollMonth" value="@Model.SelectedPayrollMonth" />
                    <div class="content-grid-2">
                        <div>
                            <label>Loại chứng từ</label>
                            <select name="documentType">
                                <option value="InvoiceIn">Hóa đơn đầu vào</option>
                                <option value="InvoiceOut">Hóa đơn đầu ra</option>
                                <option value="Receipt">Phiếu thu</option>
                                <option value="PaymentVoucher">Phiếu chi</option>
                            </select>
                        </div>
                        <div>
                            <label>Số chứng từ / hóa đơn</label>
                            <input type="text" name="documentNo" />
                        </div>
                    </div>
                    <div class="content-grid-2">
                        <div>
                            <label>Đơn vị / nhà cung cấp</label>
                            <input type="text" name="vendorName" />
                        </div>
                        <div>
                            <label>Mã số thuế</label>
                            <input type="text" name="taxCode" />
                        </div>
                    </div>
                    <div class="content-grid-3">
                        <div>
                            <label>Ngày chứng từ</label>
                            <input type="date" name="documentDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>
                        <div>
                            <label>Giá trị</label>
                            <input type="number" name="amount" step="1000" min="0" />
                        </div>
                        <div></div>
                    </div>
                    <div class="content-grid-2">
                        <div>
                            <label>Đường dẫn PDF</label>
                            <input type="text" name="pdfPath" placeholder="/uploads/.../file.pdf" />
                        </div>
                        <div>
                            <label>Đường dẫn XML</label>
                            <input type="text" name="xmlPath" placeholder="/uploads/.../file.xml" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-upload"></i> Lưu chứng từ</button>
                </form>

                <div class="finance-table-wrap">
                    <table class="finance-table">
                        <thead>
                            <tr>
                                <th>Số CT</th>
                                <th>Loại</th>
                                <th>Đối tác</th>
                                <th>MST</th>
                                <th>Ngày</th>
                                <th>PDF/XML</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (Model.AccountingDocuments.Any())
                        {
                            foreach (var doc in Model.AccountingDocuments)
                            {
                                <tr>
                                    <td>@doc.DocumentNo</td>
                                    <td>@doc.DocumentType</td>
                                    <td>@doc.VendorName</td>
                                    <td>@doc.TaxCode</td>
                                    <td>@doc.DocumentDate.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(doc.PdfPath))
                                        {
                                            <a href="@doc.PdfPath" target="_blank">PDF</a>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(doc.PdfPath) && !string.IsNullOrWhiteSpace(doc.XmlPath))
                                        {
                                            <span> / </span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(doc.XmlPath))
                                        {
                                            <a href="@doc.XmlPath" target="_blank">XML</a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="6" class="text-center text-muted">Chưa có chứng từ kế toán.</td></tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        }
    </section>

