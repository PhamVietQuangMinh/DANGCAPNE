@model List<DANGCAPNE.Models.Security.AllowedIp>
@{
    ViewData["Title"] = "Quản lý Wifi công ty";
    var detectedIp = ViewData["DetectedIp"]?.ToString() ?? "N/A";
    var activeCount = Model.Count(x => x.IsActive);
    var totalCount = Model.Count;
}

<div class="page-content wifi-page">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mb-24" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["Success"]</span>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mb-24" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@TempData["Error"]</span>
        </div>
    }

    <div class="glass-card wifi-hero mb-24">
        <div class="wifi-hero-left">
            <div class="wifi-hero-icon"><i class="bi bi-hdd-network-fill"></i></div>
            <div>
                <h2>Quản lý Wifi công ty</h2>
                <p>Chỉ cho phép đăng nhập từ mạng nội bộ đã được phê duyệt. Danh sách này giúp tăng an toàn truy cập cho toàn bộ hệ thống.</p>
            </div>
        </div>
        <div class="wifi-hero-ip">
            <div class="hero-ip-label">IP truy cập hiện tại</div>
            <div class="hero-ip-value">@detectedIp</div>
        </div>
    </div>

    <div class="wifi-stats mb-24">
        <div class="glass-card stat-card-lite">
            <div class="stat-icon success"><i class="bi bi-shield-check"></i></div>
            <div>
                <div class="stat-value">@activeCount</div>
                <div class="stat-label">Wifi đang hoạt động</div>
            </div>
        </div>
        <div class="glass-card stat-card-lite">
            <div class="stat-icon primary"><i class="bi bi-list-ul"></i></div>
            <div>
                <div class="stat-value">@totalCount</div>
                <div class="stat-label">Tổng mục đã lưu</div>
            </div>
        </div>
        <div class="glass-card stat-card-lite">
            <div class="stat-icon warning"><i class="bi bi-shield-lock-fill"></i></div>
            <div>
                <div class="stat-value">@(activeCount > 0 ? "BẬT" : "TẮT")</div>
                <div class="stat-label">Trạng thái bảo vệ</div>
            </div>
        </div>
    </div>

    @if (activeCount == 0 && totalCount > 0)
    {
        <div class="alert alert-warning mb-24" role="alert">
            <i class="bi bi-exclamation-octagon-fill"></i>
            <span>Hiện không có Wifi nào ở trạng thái hoạt động. Hãy bật ít nhất 1 Wifi để đảm bảo an toàn truy cập.</span>
        </div>
    }

    <div class="glass-card mb-24">
        <div class="card-header">
            <h3><i class="bi bi-plus-circle-fill text-primary"></i> Cấp quyền Wifi mới</h3>
        </div>
        <div class="card-body">
            <form asp-controller="IT" asp-action="Add" method="post" id="addIpForm" class="wifi-form-grid">
                @Html.AntiForgeryToken()
                <div>
                    <label class="form-label">Địa chỉ Wifi (IP)</label>
                    <input type="text" name="ipAddress" id="ipAddressInput" class="form-control" placeholder="Ví dụ: 192.168.1.50" required />
                </div>
                <div>
                    <label class="form-label">Mô tả / Vị trí</label>
                    <input type="text" name="label" class="form-control" placeholder="Ví dụ: Văn phòng Tầng 4 - CN Hà Nội" maxlength="200" />
                </div>
                <div class="form-action-wrap">
                    <button type="button" class="btn btn-primary" onclick="confirmAddIp()">
                        <i class="bi bi-plus-lg"></i> Thêm vào danh sách
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="glass-card">
        <div class="card-header table-head-wrap">
            <h3><i class="bi bi-wifi"></i> Danh sách điểm truy cập an toàn (@totalCount)</h3>
            <div class="search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" id="searchIp" class="form-control" placeholder="Tìm theo IP hoặc vị trí..." oninput="filterTable(this.value)" />
            </div>
        </div>

        <div class="card-body" style="padding:0;">
            @if (Model.Count == 0)
            {
                <div class="empty-state">
                    <i class="bi bi-wifi-off"></i>
                    <h3>Chưa có dữ liệu Wifi</h3>
                    <p>Hãy thêm điểm truy cập đầu tiên để hệ thống bắt đầu kiểm soát nguồn đăng nhập.</p>
                </div>
            }
            else
            {
                <div class="table-wrap wifi-table-wrap">
                    <table class="data-table wifi-table" id="ipTable">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Địa chỉ Wifi</th>
                                <th>Mô tả / Vị trí</th>
                                <th>Trạng thái</th>
                                <th>Người tạo</th>
                                <th class="text-right">Cài đặt</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.Count; i++)
                            {
                                var ip = Model[i];
                                <tr data-search="@ip.IpAddress @ip.Label">
                                    <td data-label="#">@(i + 1)</td>
                                    <td data-label="Địa chỉ Wifi">
                                        <span class="ip-chip">@ip.IpAddress</span>
                                    </td>
                                    <td data-label="Mô tả / Vị trí">@(string.IsNullOrWhiteSpace(ip.Label) ? "-" : ip.Label)</td>
                                    <td data-label="Trạng thái">
                                        @if (ip.IsActive)
                                        {
                                            <span class="status-badge approved"><i class="bi bi-check2-circle"></i> Đang hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge draft"><i class="bi bi-pause-circle"></i> Tạm dừng</span>
                                        }
                                    </td>
                                    <td data-label="Người tạo">
                                        <div class="creator-name">@(ip.AddedByUser?.FullName ?? "Hệ thống")</div>
                                        <div class="text-muted" style="font-size:11px;">@ip.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</div>
                                    </td>
                                    <td data-label="Cài đặt" class="text-right">
                                        <div class="inline-actions" style="justify-content:flex-end;">
                                            <form asp-controller="IT" asp-action="Toggle" asp-route-id="@ip.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-outline btn-sm"
                                                        onclick="return confirm('@(ip.IsActive ? $"Xác nhận tạm dừng Wifi {ip.IpAddress}?" : $"Kích hoạt lại Wifi {ip.IpAddress}?")')">
                                                    <i class="bi @(ip.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                                    @(ip.IsActive ? "Tạm dừng" : "Bật lại")
                                                </button>
                                            </form>
                                            <form asp-controller="IT" asp-action="Delete" asp-route-id="@ip.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-danger btn-sm"
                                                        onclick="return confirm('Xóa vĩnh viễn Wifi @ip.IpAddress?')">
                                                    <i class="bi bi-trash3"></i> Xóa
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .wifi-page .alert {
        border-radius: 12px;
        border: 1px solid var(--border-glass);
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
    }

    .wifi-hero {
        padding: 18px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        background: linear-gradient(135deg, rgba(92, 103, 242, 0.18), rgba(124, 58, 237, 0.12));
    }

    .wifi-hero-left {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .wifi-hero-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        color: #ffffff;
        background: var(--accent-gradient);
        flex-shrink: 0;
    }

    .wifi-hero h2 {
        margin: 0;
        font-size: 24px;
        font-weight: 800;
    }

    .wifi-hero p {
        margin: 4px 0 0;
        color: var(--text-secondary);
    }

    .wifi-hero-ip {
        min-width: 180px;
        border: 1px solid var(--border-glass);
        border-radius: 12px;
        padding: 8px 12px;
        background: rgba(255, 255, 255, 0.6);
    }

    .hero-ip-label {
        font-size: 11px;
        color: var(--text-muted);
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 0.4px;
    }

    .hero-ip-value {
        font-size: 16px;
        font-weight: 700;
        font-family: "Consolas", "Courier New", monospace;
    }

    .wifi-stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
    }

    .stat-card-lite {
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .stat-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

    .stat-icon.success { color: #047857; background: #d1fae5; }
    .stat-icon.primary { color: #1d4ed8; background: #dbeafe; }
    .stat-icon.warning { color: #b45309; background: #fef3c7; }

    .stat-value {
        font-size: 28px;
        font-weight: 800;
        line-height: 1;
    }

    .stat-label {
        margin-top: 3px;
        color: var(--text-muted);
        font-size: 12px;
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 0.4px;
    }

    .wifi-form-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr auto;
        gap: 12px;
        align-items: end;
    }

    .form-action-wrap {
        display: flex;
        align-items: end;
    }

    .table-head-wrap {
        gap: 12px;
    }

    .search-wrap {
        min-width: 280px;
        position: relative;
    }

    .search-wrap i {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        pointer-events: none;
    }

    .search-wrap .form-control {
        padding-left: 34px;
    }

    .wifi-table th,
    .wifi-table td {
        text-align: left !important;
        padding: 12px 16px !important;
        vertical-align: middle;
    }

    .wifi-table th {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-muted);
        border-bottom: 1px solid var(--border-glass);
    }

    .wifi-table tbody tr:hover {
        background: rgba(92, 103, 242, 0.04);
    }

    .ip-chip {
        display: inline-block;
        border-radius: 999px;
        border: 1px solid rgba(92, 103, 242, 0.25);
        background: rgba(92, 103, 242, 0.08);
        color: #4338ca;
        padding: 4px 10px;
        font-family: "Consolas", "Courier New", monospace;
        font-weight: 700;
        font-size: 12px;
    }

    .creator-name {
        font-weight: 700;
    }

    @@media (max-width: 1100px) {
        .wifi-form-grid {
            grid-template-columns: 1fr;
        }

        .form-action-wrap {
            justify-content: flex-start;
        }
    }

    @@media (max-width: 900px) {
        .wifi-stats {
            grid-template-columns: 1fr;
        }

        .wifi-hero {
            flex-direction: column;
            align-items: stretch;
        }

        .wifi-hero-ip {
            min-width: 0;
        }

        .table-head-wrap {
            flex-direction: column;
            align-items: stretch;
        }

        .search-wrap {
            min-width: 0;
            width: 100%;
        }
    }

    @@media (max-width: 760px) {
        .wifi-table-wrap {
            overflow: visible;
        }

        .wifi-table thead {
            display: none;
        }

        .wifi-table,
        .wifi-table tbody,
        .wifi-table tr,
        .wifi-table td {
            display: block;
            width: 100%;
        }

        .wifi-table tr {
            padding: 12px 16px;
            border-bottom: 1px solid var(--border-glass);
        }

        .wifi-table td {
            border: 0;
            padding: 0 0 10px 0 !important;
            text-align: left !important;
            white-space: normal;
            overflow-wrap: anywhere;
        }

        .wifi-table td:last-child {
            padding-bottom: 0 !important;
        }

        .wifi-table td::before {
            content: attr(data-label);
            display: block;
            margin-bottom: 4px;
            font-size: 11px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .wifi-table td.text-right {
            text-align: left !important;
        }

        .wifi-table .inline-actions {
            justify-content: flex-start !important;
            flex-wrap: wrap;
        }
    }
</style>

@section Scripts {
<script>
    function filterTable(value) {
        const query = (value || '').toLowerCase();
        document.querySelectorAll('#ipTable tbody tr').forEach(function (row) {
            const text = (row.dataset.search || '').toLowerCase();
            row.style.display = text.includes(query) ? '' : 'none';
        });
    }

    function confirmAddIp() {
        const input = document.getElementById('ipAddressInput');
        const ip = (input?.value || '').trim();

        if (!ip) {
            alert('Vui lòng nhập địa chỉ Wifi.');
            return;
        }

        if (confirm('Thêm Wifi "' + ip + '" vào danh sách truy cập an toàn?')) {
            document.getElementById('addIpForm').submit();
        }
    }
</script>
}
