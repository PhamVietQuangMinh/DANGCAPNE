@model DANGCAPNE.ViewModels.AccountantDashboardViewModel
@{
    ViewData["Title"] = "Dashboard kế toán";
}

<style>
    .finance-shell {
        display: grid;
        gap: 24px;
    }

    .finance-hero {
        display: grid;
        grid-template-columns: minmax(0, 1.6fr) minmax(320px, 0.9fr);
        gap: 24px;
        align-items: stretch;
    }

    .finance-banner {
        position: relative;
        overflow: hidden;
        padding: 28px;
        color: #f8fafc;
        background:
            radial-gradient(circle at top right, rgba(251, 191, 36, 0.20), transparent 28%),
            radial-gradient(circle at bottom left, rgba(59, 130, 246, 0.18), transparent 34%),
            linear-gradient(135deg, #0b132b 0%, #1e293b 52%, #334155 100%);
    }

    .finance-banner::after {
        content: "";
        position: absolute;
        inset: auto -40px -70px auto;
        width: 180px;
        height: 180px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.05);
    }

    .finance-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,0.10);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .finance-title {
        margin: 16px 0 10px;
        font-size: clamp(28px, 4vw, 42px);
        font-weight: 900;
        line-height: 1.05;
        color: #f8fafc;
        text-shadow: 0 6px 24px rgba(15, 23, 42, 0.38);
    }

    .finance-subtitle {
        max-width: 700px;
        font-size: 15px;
        line-height: 1.7;
        color: rgba(248,250,252,0.82);
    }

    .finance-hero-metrics {
        margin-top: 22px;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
    }

    .finance-hero-metric {
        padding: 14px 16px;
        border-radius: 18px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.08);
        backdrop-filter: blur(8px);
    }

    .finance-hero-metric label {
        display: block;
        font-size: 12px;
        color: rgba(248,250,252,0.72);
        margin-bottom: 6px;
    }

    .finance-hero-metric strong {
        font-size: 24px;
        font-weight: 900;
    }

    .finance-control-card {
        padding: 24px;
        background: linear-gradient(180deg, #fff7ed 0%, #ffffff 100%);
        border: 1px solid rgba(249, 115, 22, 0.18);
    }

    .finance-control-card h3 {
        margin-bottom: 6px;
    }

    .finance-control-card p {
        color: var(--text-muted);
        font-size: 14px;
        line-height: 1.6;
    }

    .finance-form-grid {
        display: grid;
        gap: 14px;
        margin-top: 18px;
    }

    .finance-form-grid label {
        display: block;
        margin-bottom: 6px;
        font-weight: 700;
        font-size: 13px;
        color: #0f172a;
    }

    .finance-form-grid input,
    .finance-form-grid textarea,
    .finance-form-grid select {
        width: 100%;
        border-radius: 14px;
        border: 1px solid #d6d3d1;
        background: #fff;
        padding: 12px 14px;
        font: inherit;
    }

    .finance-form-grid textarea {
        min-height: 92px;
        resize: vertical;
    }

    .finance-status-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-top: 14px;
        padding: 10px 12px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 700;
    }

    .finance-status-chip.open {
        background: #ecfeff;
        color: #155e75;
    }

    .finance-status-chip.closed {
        background: #dcfce7;
        color: #166534;
    }

    .finance-stats-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
    }

    .finance-stat {
        position: relative;
        overflow: hidden;
        padding: 22px 20px;
        border-radius: 22px;
        border: 1px solid rgba(15, 23, 42, 0.06);
        background: #fff;
    }

    .finance-stat:nth-child(1) { background: linear-gradient(135deg, #eef2ff 0%, #ffffff 100%); }
    .finance-stat:nth-child(2) { background: linear-gradient(135deg, #e0f2fe 0%, #ffffff 100%); }
    .finance-stat:nth-child(3) { background: linear-gradient(135deg, #fff7ed 0%, #ffffff 100%); }
    .finance-stat:nth-child(4) { background: linear-gradient(135deg, #fdf2f8 0%, #ffffff 100%); }

    .finance-stat-label {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #64748b;
    }

    .finance-stat-value {
        margin: 8px 0 6px;
        font-size: 34px;
        font-weight: 900;
        color: #0f172a;
    }

    .finance-stat-sub {
        font-size: 13px;
        color: #475569;
    }

    .finance-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
        gap: 24px;
    }

    .finance-panel {
        overflow: hidden;
    }

    .finance-panel .card-header {
        padding-bottom: 0;
    }

    .finance-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .finance-month-switcher {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .finance-month-switcher input {
        min-width: 160px;
        border-radius: 12px;
        border: 1px solid #cbd5e1;
        padding: 10px 12px;
        background: #fff;
        font: inherit;
    }

    .finance-table {
        width: 100%;
        min-width: 640px;
        border-collapse: collapse;
    }

    .finance-table th,
    .finance-table td {
        padding: 14px 16px;
        text-align: left;
        border-bottom: 1px solid rgba(148, 163, 184, 0.16);
        vertical-align: middle;
    }

    .finance-table th {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #64748b;
    }

    .finance-table-wrap {
        overflow-x: auto;
    }

    .finance-list {
        display: grid;
        gap: 14px;
        padding: 20px;
    }

    .finance-list-item {
        padding: 16px;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid rgba(148, 163, 184, 0.16);
    }

    .finance-list-item-top {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: flex-start;
        margin-bottom: 8px;
    }

    .finance-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    .finance-tag.warn {
        background: #fef3c7;
        color: #92400e;
    }

    .finance-tag.ok {
        background: #dcfce7;
        color: #166534;
    }

    .finance-caption {
        font-size: 13px;
        color: #64748b;
    }

    .finance-formula {
        padding: 18px 20px;
        border-radius: 18px;
        background: linear-gradient(135deg, #eff6ff 0%, #ffffff 100%);
        border: 1px solid rgba(59, 130, 246, 0.14);
    }

    .finance-formula code {
        display: block;
        margin-top: 8px;
        padding: 10px 12px;
        border-radius: 12px;
        background: #0f172a;
        color: #e2e8f0;
        white-space: normal;
    }

    .finance-action-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
    }

    .finance-action-item {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 16px;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid rgba(148, 163, 184, 0.16);
        color: inherit;
        text-decoration: none;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }

    .finance-action-item:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
        border-color: rgba(59, 130, 246, 0.22);
    }

    .finance-action-icon {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #dbeafe 0%, #eff6ff 100%);
        color: #2563eb;
        font-size: 18px;
        flex-shrink: 0;
    }

    .finance-action-item strong {
        display: block;
        margin-bottom: 4px;
        color: #0f172a;
    }

    .finance-action-item span {
        display: block;
        font-size: 13px;
        color: #64748b;
        line-height: 1.5;
    }

    .finance-mini-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
    }

    .finance-mini-card {
        padding: 18px;
        border-radius: 18px;
        background: #fff;
        border: 1px solid rgba(148, 163, 184, 0.16);
    }

    .finance-mini-card h4 {
        margin: 0 0 8px;
        font-size: 13px;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: .05em;
    }

    .finance-mini-card strong {
        font-size: 28px;
        color: #0f172a;
    }

    .finance-report-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    @@media (max-width: 1180px) {
        .finance-hero,
        .finance-grid {
            grid-template-columns: 1fr;
        }

        .finance-mini-grid,
        .finance-action-grid,
        .finance-stats-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 720px) {
        .finance-hero-metrics,
        .finance-mini-grid,
        .finance-action-grid,
        .finance-stats-grid {
            grid-template-columns: 1fr;
        }

        .finance-banner,
        .finance-control-card {
            padding: 20px;
        }

        .finance-panel-header {
            align-items: flex-start;
        }
    }
</style>

<div class="page-content finance-shell">
    <section class="finance-hero">
        <div class="glass-card finance-banner stagger-elem">
            <div class="finance-kicker">
                <i class="bi bi-bank2"></i>
                Điều hành kỳ lương @Model.SelectedPayrollMonth
            </div>
            <h1 class="finance-title">Trung tâm vận hành bảng lương, công, OT và đối soát tài chính nội bộ.</h1>
            <p class="finance-subtitle">
                Theo dõi nhân sự tính lương, rà soát công - tăng ca - tạm ứng, kiểm soát hồ sơ chờ duyệt và khóa sổ kỳ lương theo đúng quy trình doanh nghiệp.
            </p>

            <div class="finance-hero-metrics">
                <div class="finance-hero-metric">
                    <label>Nhân sự tính lương</label>
                    <strong>@(Model.IsChiefAccountant ? Model.TotalPayrollEmployees.ToString() : "--")</strong>
                </div>
                <div class="finance-hero-metric">
                    <label>Tổng giờ công</label>
                    <strong>@(Model.IsChiefAccountant ? Model.TotalWorkHours.ToString("N1") : "--")</strong>
                </div>
                <div class="finance-hero-metric">
                    <label>Thông báo chưa đọc</label>
                    <strong>@Model.UnreadNotifications</strong>
                </div>
            </div>
        </div>

        <div class="glass-card finance-control-card stagger-elem">
            <h3><i class="bi bi-lock-fill text-warning"></i> Chốt lương theo tháng</h3>
            <p>Chức năng này dùng để khóa kỳ lương sau khi đã rà soát công, OT và các khoản tạm ứng liên quan.</p>

            <form method="get" asp-action="Index" asp-controller="Home" class="finance-form-grid" style="margin-bottom:16px;">
                <div>
                    <label for="payrollMonthFilter">Tháng cần xem</label>
                    <input id="payrollMonthFilter" type="month" name="payrollMonth" value="@Model.SelectedPayrollMonth" />
                </div>
                <button type="submit" class="btn btn-outline">
                    <i class="bi bi-search"></i> Xem dữ liệu tháng
                </button>
            </form>

            @if (Model.IsChiefAccountant)
            {
                <form method="post" asp-action="ClosePayroll" asp-controller="Home" class="finance-form-grid">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="payrollMonth" value="@Model.SelectedPayrollMonth" />
                    <div>
                        <label for="closureNotes">Ghi chú chốt lương</label>
                        <textarea id="closureNotes" name="notes" placeholder="Ví dụ: Đã đối soát OT, đã xác nhận tạm ứng lương và khóa bảng công."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary" @(Model.IsMonthClosed ? "disabled" : null)>
                        <i class="bi bi-check2-square"></i> Chốt lương tháng @Model.SelectedPayrollMonth
                    </button>
                </form>

                <div class="finance-status-chip @(Model.IsMonthClosed ? "closed" : "open")">
                    <i class="bi @(Model.IsMonthClosed ? "bi-shield-check" : "bi-hourglass-split")"></i>
                    @(Model.IsMonthClosed ? $"Tháng {Model.SelectedPayrollMonth} đã được chốt." : $"Tháng {Model.SelectedPayrollMonth} chưa chốt, vẫn có thể tiếp tục rà soát.")
                </div>
            }
            else
            {
                <div class="finance-status-chip open">
                    <i class="bi bi-info-circle"></i>
                    Tài khoản nhân viên kế toán: không có quyền chốt lương / xem hồ sơ lương.
                </div>
            }
        </div>
    </section>

    <section class="glass-card finance-panel stagger-elem">
        <div class="card-header">
            <h3><i class="bi bi-lightning-charge text-warning"></i> Tác vụ kế toán trọng tâm</h3>
            <span class="finance-caption">Các thao tác dùng nhiều trong kỳ chấm công và chốt lương</span>
        </div>
        <div class="card-body">
            <div class="finance-action-grid">
                @if (Model.IsChiefAccountant)
                {
                    <a class="finance-action-item" href="@Url.Action("PayrollRecords", "Home", new { payrollMonth = Model.SelectedPayrollMonth })">
                        <div class="finance-action-icon"><i class="bi bi-wallet2"></i></div>
                        <div>
                            <strong>Hồ sơ lương</strong>
                            <span>Xem phiếu lương, tổng thực lĩnh và dữ liệu đã chốt theo tháng.</span>
                        </div>
                    </a>
                }
                @if (Model.IsChiefAccountant)
                {
                    <a class="finance-action-item" href="@Url.Action("Index", "Approvals")">
                        <div class="finance-action-icon"><i class="bi bi-check2-square"></i></div>
                        <div>
                            <strong>Danh sách chờ duyệt</strong>
                            <span>Truy cập nhanh các hồ sơ tài chính và chứng từ đang chờ kế toán xử lý.</span>
                        </div>
                    </a>
                }
                <a class="finance-action-item" href="@Url.Action("Index", "Notifications")">
                    <div class="finance-action-icon"><i class="bi bi-bell"></i></div>
                    <div>
                        <strong>Thông báo nghiệp vụ</strong>
                        <span>Theo dõi cảnh báo mới, thay đổi hồ sơ lương và nhắc việc đối soát.</span>
                    </div>
                </a>
                <a class="finance-action-item" href="@Url.Action("Index", "Requests")">
                    <div class="finance-action-icon"><i class="bi bi-file-earmark-text"></i></div>
                    <div>
                        <strong>Tra cứu đơn từ</strong>
                        <span>Mở danh sách đơn để đối chiếu nguồn dữ liệu trước khi khóa sổ.</span>
                    </div>
                </a>
            </div>
        </div>
    </section>

    <section class="finance-stats-grid stagger-elem">
        <article class="finance-stat">
            <div class="finance-stat-label">Bản ghi chấm công</div>
            <div class="finance-stat-value">@Model.TotalTimesheets</div>
            <div class="finance-stat-sub">Tổng bản ghi công trong kỳ lương đang xem</div>
        </article>
        <article class="finance-stat">
            <div class="finance-stat-label">Hồ sơ chờ kế toán xử lý</div>
            <div class="finance-stat-value">@Model.PendingFinanceApprovals</div>
            <div class="finance-stat-sub">Các yêu cầu nghiệp vụ đang chờ xác nhận hoặc phê duyệt</div>
        </article>
        <article class="finance-stat">
            <div class="finance-stat-label">Tạm ứng cần theo dõi</div>
            <div class="finance-stat-value">@Model.PendingSalaryAdvanceCount</div>
            <div class="finance-stat-sub">Các khoản cần bám sát để khấu trừ hoặc đối chiếu trong kỳ</div>
        </article>
        <article class="finance-stat">
            <div class="finance-stat-label">Điểm cần rà soát</div>
            <div class="finance-stat-value">@(Model.LateAttendanceCount + Model.AbsentAttendanceCount)</div>
            <div class="finance-stat-sub">@Model.LateAttendanceCount đi muộn, @Model.AbsentAttendanceCount vắng công cần kiểm tra</div>
        </article>
    </section>

    <section class="finance-mini-grid stagger-elem">
        <article class="finance-mini-card">
            <h4>Tổng thu tháng</h4>
            <strong>@Model.TotalCashIn.ToString("N0")</strong>
            <div class="finance-caption">Dòng tiền vào đã ghi nhận trong kỳ</div>
        </article>
        <article class="finance-mini-card">
            <h4>Tổng chi tháng</h4>
            <strong>@Model.TotalCashOut.ToString("N0")</strong>
            <div class="finance-caption">Dòng tiền ra đã ghi nhận trong kỳ</div>
        </article>
        <article class="finance-mini-card">
            <h4>Số dư quỹ tiền mặt</h4>
            <strong>@Model.CashOnHand.ToString("N0")</strong>
            <div class="finance-caption">Theo các phiếu thu/chi kênh tiền mặt</div>
        </article>
        <article class="finance-mini-card">
            <h4>Số dư ngân hàng</h4>
            <strong>@Model.BankBalance.ToString("N0")</strong>
            <div class="finance-caption">Theo các giao dịch chuyển khoản đã ghi nhận</div>
        </article>
    </section>

    <section class="finance-grid">
        <div class="glass-card finance-panel stagger-elem">
            <div class="card-header">
                <h3><i class="bi bi-cash-stack text-success"></i> Lập phiếu thu / chi</h3>
                <span class="finance-caption">Ghi nhận nghiệp vụ thu tiền, chi tiền và cập nhật sổ quỹ nội bộ</span>
            </div>
            <div class="card-body">
                <form method="post" asp-action="CreateCashTransaction" asp-controller="Home" class="finance-form-grid">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="payrollMonth" value="@Model.SelectedPayrollMonth" />
                    <div class="content-grid-2">
                        <div>
                            <label>Loại phiếu</label>
                            <select name="transactionType">
                                <option value="Income">Phiếu thu</option>
                                <option value="Expense">Phiếu chi</option>
                            </select>
                        </div>
                        <div>
                            <label>Kênh tiền</label>
                            <select name="channel">
                                <option value="Cash">Tiền mặt</option>
                                <option value="Bank">Ngân hàng</option>
                            </select>
                        </div>
                    </div>
                    <div class="content-grid-2">
                        <div>
                            <label>Ngày giao dịch</label>
                            <input type="date" name="transactionDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>
                        <div>
                            <label>Số tiền</label>
                            <input type="number" name="amount" min="0" step="1000" />
                        </div>
                    </div>
                    <div class="content-grid-2">
                        <div>
                            <label>Đối tượng</label>
                            <input type="text" name="counterpartyName" placeholder="Khách hàng / NCC / nhân viên" />
                        </div>
                        <div>
                            <label>Loại đối tượng</label>
                            <select name="counterpartyType">
                                <option value="Customer">Khách hàng</option>
                                <option value="Vendor">Nhà cung cấp</option>
                                <option value="Employee">Nhân viên</option>
                                <option value="Other">Khác</option>
                            </select>
                        </div>
                    </div>
                    <div class="content-grid-2">
                        <div>
                            <label>Mã tham chiếu</label>
                            <input type="text" name="referenceCode" placeholder="PT-2026-001 / UNC-..." />
                        </div>
                        <div>
                            <label>Nội dung</label>
                            <input type="text" name="content" placeholder="Nội dung phiếu thu/chi" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save2"></i> Ghi nhận thu / chi</button>
                </form>
            </div>
        </div>

        <div class="glass-card finance-panel stagger-elem">
            <div class="card-header">
                <h3><i class="bi bi-clipboard-data text-info"></i> Công nợ đến hạn 3-5 ngày</h3>
                <span class="finance-caption">Danh sách cần thu hoặc cần trả sắp đến hạn</span>
            </div>
            <div class="finance-list">
                @if (Model.DueInvoices.Any())
                {
                    foreach (var invoice in Model.DueInvoices)
                    {
                        <article class="finance-list-item">
                            <div class="finance-list-item-top">
                                <div>
                                    <strong>@invoice.InvoiceNo</strong>
                                    <div class="finance-caption">@invoice.CounterpartyName · @invoice.DueDate.ToString("dd/MM/yyyy")</div>
                                </div>
                                <span class="finance-tag @(invoice.InvoiceType == "Receivable" ? "warn" : "ok")">@(invoice.InvoiceType == "Receivable" ? "Cần thu" : "Cần trả")</span>
