@model DANGCAPNE.ViewModels.ModulesIndexViewModel
@using System.Text
@{
    ViewData["TitleI18n"] = "NavModules";
    ViewData["Title"] = "Phân hệ";

    string FixText(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return string.Empty;
        }

        var value = text.Trim();
        if (!(value.Contains('Ã') || value.Contains('Â') || value.Contains('Ä') || value.Contains('á')))
        {
            return value;
        }

        try
        {
            var bytes = Encoding.GetEncoding(1252).GetBytes(value);
            return Encoding.UTF8.GetString(bytes);
        }
        catch
        {
            return value;
        }
    }
}

<div class="page-content">
    @if (Model.Sections.Any())
    {
        @foreach (var moduleSection in Model.Sections)
        {
            <div class="glass-card" style="margin-bottom:20px;">
                <div class="card-header">
                    <div>
                        <h3><i class="bi bi-grid-3x3-gap-fill text-primary"></i> @FixText(moduleSection.Title)</h3>
                        <div class="text-muted" style="font-size:14px; margin-top:4px;">@FixText(moduleSection.Description)</div>
                    </div>
                    <div class="badge-soft" style="align-self:flex-start;">@FixText(moduleSection.Audience)</div>
                </div>
                <div class="card-body">
                    <div class="grid-3">
                        @foreach (var m in moduleSection.Modules)
                        {
                            <a href="@Url.Action("List", "Modules", new { key = m.Key })" class="module-card">
                                <div class="module-title">@FixText(m.Title)</div>
                                <div class="module-desc">@FixText(m.Description)</div>
                                <div class="module-desc" style="margin-top:8px; font-size:12px; color:var(--text-muted);">@FixText(m.Audience)</div>
                                <div class="module-cta" data-i18n="BtnManage">Quản lý</div>
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="glass-card">
            <div class="card-header">
                <h3><i class="bi bi-grid-3x3-gap-fill text-primary"></i> <span data-i18n="ModulesExt">Phân hệ mở rộng</span></h3>
            </div>
            <div class="card-body">
                <div class="grid-3">
                    @foreach (var m in Model.Modules)
                    {
                        <a href="@Url.Action("List", "Modules", new { key = m.Key })" class="module-card">
                            <div class="module-title">@FixText(m.Title)</div>
                            <div class="module-desc">@FixText(m.Description)</div>
                            <div class="module-cta" data-i18n="BtnManage">Quản lý</div>
                        </a>
                    }
                    @if (!Model.Modules.Any())
                    {
                        <div class="empty-state" style="grid-column:1/-1">
                            <i class="bi bi-shield-lock"></i>
                            <p data-i18n="ModulesNoAccess">Bạn không có quyền truy cập phân hệ nào.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
