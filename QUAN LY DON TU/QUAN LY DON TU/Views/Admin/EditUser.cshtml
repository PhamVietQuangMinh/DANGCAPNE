@model DANGCAPNE.ViewModels.UserEditViewModel
@{
    ViewData["TitleI18n"] = Model.User?.Id > 0 ? "EditUserTitle" : "AddUserTitle";
    ViewData["Title"] = Model.User?.Id > 0 ? "Chỉnh sửa nhân viên" : "Thêm nhân viên";
}
<div class="page-content">
    <div style="max-width:800px;margin:0 auto">
        <div class="glass-card">
            <div class="card-header">
                <h3><i class="bi bi-person-gear text-primary"></i> <span data-i18n="@ViewData["TitleI18n"]">@ViewData["Title"]</span></h3>
            </div>
            <div class="card-body">
                <form method="post" asp-action="SaveUser">
                    <input type="hidden" name="User.Id" value="@(Model.User?.Id ?? 0)" />
                    <div class="form-row">
                        <div class="col-6">
                            <div class="form-group">
                                <label class="form-label"><span data-i18n="ColName">Họ và tên</span> *</label>
                                <input type="text" name="User.FullName" class="form-control" value="@Model.User?.FullName" required />
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label class="form-label"><span data-i18n="ColCode">Mã nhân viên</span></label>
                                <input type="text" name="User.EmployeeCode" class="form-control" value="@Model.User?.EmployeeCode" />
                                @if (Model.CanAutoGenerateEmployeeCode)
                                {
                                    <div class="text-muted" style="font-size:12px; margin-top:6px;">
                                        Để trống nếu muốn hệ thống tự cấp mã theo phòng ban khi lưu. Ví dụ: <strong>IT001</strong>, <strong>HR001</strong>, <strong>KT001</strong>.
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label class="form-label">Email *</label>
                                <input type="email" name="User.Email" class="form-control" value="@Model.User?.Email" required />
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label class="form-label" data-i18n="ColDept">Phòng ban</label>
                                <select name="User.DepartmentId" class="form-control">
                                    <option value="" data-i18n="OptSelect">-- Chọn --</option>
                                    @foreach (var d in Model.Departments)
                                    {
                                        <option value="@d.Id" selected="@(Model.User?.DepartmentId == d.Id)">@d.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label class="form-label" data-i18n="LabelBranch">Chi nhánh</label>
                                <select name="User.BranchId" class="form-control">
                                    <option value="" data-i18n="OptSelect">-- Chọn --</option>
                                    @foreach (var b in Model.Branches)
                                    {
                                        <option value="@b.Id" selected="@(Model.User?.BranchId == b.Id)">@b.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label class="form-label" data-i18n="LabelJobTitle">Chức danh</label>
                                <select name="User.JobTitleId" class="form-control">
                                    <option value="" data-i18n="OptSelect">-- Chọn --</option>
                                    @foreach (var j in Model.JobTitles)
                                    {
                                        <option value="@j.Id" selected="@(Model.User?.JobTitleId == j.Id)">@j.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label class="form-label" data-i18n="LabelDirectMgr">Quản lý trực tiếp</label>
                                <select name="ManagerId" class="form-control">
                                    <option value="" data-i18n="OptSelect">-- Chọn --</option>
                                    @foreach (var m in Model.PotentialManagers)
                                    {
                                        <option value="@m.Id" selected="@(Model.ManagerId == m.Id)">@m.FullName (@m.EmployeeCode)</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label class="form-label">Ngày nhận việc</label>
                                <input type="date" name="User.HireDate" class="form-control" value="@(Model.User?.HireDate.ToString("yyyy-MM-dd"))" />
                            </div>
                        </div>
                        @if (Model.CanManageRoles)
                        {
                            <div class="col-12">
                                <div class="form-group">
                                    <label class="form-label">Vai trò hệ thống</label>
                                    <div class="role-check-grid">
                                        @foreach (var role in Model.AllRoles)
                                        {
                                            <label class="role-check-item">
                                                <input type="checkbox" name="roleIds" value="@role.Id" checked="@(Model.SelectedRoleIds.Contains(role.Id))" />
                                                <span>
                                                    <strong>@role.Name</strong>
                                                    <small>@role.Description</small>
                                                </span>
                                            </label>
                                        }
                                    </div>
                                    <div class="text-muted" style="font-size:12px; margin-top:8px;">
                                        Có thể gán nhiều vai trò cho cùng một tài khoản. Role <strong>IT</strong> dùng cho cấp mã nhân viên và hỗ trợ kỹ thuật truy cập.
                                    </div>
                                </div>
                            </div>
                        }
                        <div class="col-12">
                            <div class="form-group">
                                <label class="form-label">Thiết lập lương</label>
                                <div class="form-row">
                                    <div class="col-6">
                                        <label class="form-label">Lương cơ bản</label>
                                        <input type="number" min="0" step="1000" name="User.BaseSalary" class="form-control" value="@(Model.User?.BaseSalary ?? 0)" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Hệ số lương</label>
                                        <input type="number" min="0.1" step="0.1" name="User.SalaryCoefficient" class="form-control" value="@(Model.User?.SalaryCoefficient ?? 1)" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Chuẩn ngày công / tháng</label>
                                        <input type="number" min="1" step="1" name="User.StandardWorkDays" class="form-control" value="@(Model.User?.StandardWorkDays ?? 26)" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Chuẩn giờ / ngày</label>
                                        <input type="number" min="1" step="0.5" name="User.StandardWorkHoursPerDay" class="form-control" value="@(Model.User?.StandardWorkHoursPerDay ?? 8)" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Hệ số OT</label>
                                        <input type="number" min="1" step="0.1" name="User.OvertimeHourlyMultiplier" class="form-control" value="@(Model.User?.OvertimeHourlyMultiplier ?? 1.5m)" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Phạt đi trễ / phút</label>
                                        <input type="number" min="0" step="500" name="User.LatePenaltyPerMinute" class="form-control" value="@(Model.User?.LatePenaltyPerMinute ?? 2000)" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Phụ cấp cố định</label>
                                        <input type="number" min="0" step="1000" name="User.FixedAllowance" class="form-control" value="@(Model.User?.FixedAllowance ?? 0)" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Thu nhập khác</label>
                                        <input type="number" min="0" step="1000" name="User.OtherIncome" class="form-control" value="@(Model.User?.OtherIncome ?? 0)" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="action-row" style="margin-top:24px;padding-top:24px;border-top:1px solid var(--border-glass)">
                        <a href="@Url.Action("Index", new { tab = "users" })" class="btn btn-outline"><i class="bi bi-arrow-left"></i> <span data-i18n="BtnBack">Quay lại</span></a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> <span data-i18n="BtnSaveInfo">Lưu thông tin</span></button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .role-check-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
        gap: 12px;
    }

    .role-check-item {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        padding: 12px 14px;
        border: 1px solid var(--border-glass);
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.7);
        cursor: pointer;
    }

    .role-check-item input {
        margin-top: 4px;
    }

    .role-check-item span {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .role-check-item small {
        color: var(--text-muted);
        line-height: 1.4;
    }
</style>
