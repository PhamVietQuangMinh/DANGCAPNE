@model DANGCAPNE.ViewModels.AdminViewModel
@{
    var activeTab = (Model.ActiveTab ?? "users").ToLowerInvariant();
    var pageTitle = activeTab == "timekeeping" ? "Quản lý chấm công" : "Quản lý nhân viên";
    var pageSubtitle = activeTab == "timekeeping"
        ? "Theo dõi lịch sử chấm công, bộ lọc phòng ban và chỉnh sửa bản ghi công."
        : "Xem danh sách nhân viên và dữ liệu được tải trực tiếp từ cơ sở dữ liệu trên server.";
    ViewData["Title"] = pageTitle;
}

<div class="page-content">
    <div class="d-flex justify-between align-center mb-24" style="gap:16px; flex-wrap:wrap;">
        <div>
            <h2 style="margin:0; font-size:28px; font-weight:800;">@pageTitle</h2>
            <p class="text-muted" style="margin-top:6px;">@pageSubtitle</p>
        </div>
        <div class="d-flex gap-12 flex-wrap">
            <a class="btn @(activeTab == "users" ? "btn-primary" : "btn-outline")" href="@Url.Action("Index", new { tab = "users", employeeSearch = Model.EmployeeSearch, employeeDepartmentId = Model.EmployeeDepartmentId })">
                <i class="bi bi-people-fill"></i> Nhân viên
            </a>
            <a class="btn @(activeTab == "timekeeping" ? "btn-primary" : "btn-outline")" href="@Url.Action("Index", new { tab = "timekeeping", attendanceSearch = Model.AttendanceSearch, attendanceDepartmentId = Model.AttendanceDepartmentId, attendanceFromDate = Model.AttendanceFromDate?.ToString("yyyy-MM-dd"), attendanceToDate = Model.AttendanceToDate?.ToString("yyyy-MM-dd") })">
                <i class="bi bi-calendar-check"></i> Chấm công
            </a>
        </div>
    </div>

    @if (activeTab == "timekeeping")
    {
        <div class="glass-card mb-24">
            <div class="card-header">
                <h3><i class="bi bi-funnel"></i> Bộ lọc chấm công</h3>
            </div>
            <div class="card-body">
                <form method="get" asp-action="Index">
                    <input type="hidden" name="tab" value="timekeeping" />
                    <div class="form-row">
                        <div class="col-3">
                            <label class="form-label">Từ ngày</label>
                            <input type="date" class="form-control" name="attendanceFromDate" value="@Model.AttendanceFromDate?.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-3">
                            <label class="form-label">Đến ngày</label>
                            <input type="date" class="form-control" name="attendanceToDate" value="@Model.AttendanceToDate?.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-3">
                            <label class="form-label">Phòng ban</label>
                            <select class="form-control" name="attendanceDepartmentId">
                                <option value="">Tất cả phòng ban</option>
                                @foreach (var dept in Model.Departments.OrderBy(d => d.Name))
                                {
                                    <option value="@dept.Id" selected="@(Model.AttendanceDepartmentId == dept.Id)">@dept.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-3">
                            <label class="form-label">Tìm nhân viên</label>
                            <input type="text" class="form-control" name="attendanceSearch" value="@Model.AttendanceSearch" placeholder="Tên, email, mã NV" />
                        </div>
                    </div>
                    <div class="d-flex gap-12 flex-wrap" style="margin-top:16px;">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Lọc dữ liệu</button>
                        <a href="@Url.Action("Index", new { tab = "timekeeping" })" class="btn btn-outline">Đặt lại</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="glass-card">
            <div class="card-header d-flex justify-between align-center">
                <h3><i class="bi bi-table"></i> Bảng Chấm công</h3>
                <span class="text-muted">@Model.Timesheets.Count bản ghi</span>
            </div>
            <div class="card-body" style="padding:0; overflow-x:auto;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Ngày</th>
                            <th>Nhân viên</th>
                            <th>Phòng ban</th>
                            <th>Giờ vào</th>
                            <th>Giờ ra</th>
                            <th>Giờ công</th>
                            <th>Ghi chú</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Timesheets.Any())
                        {
                            @foreach (var item in Model.Timesheets)
                            {
                                <tr>
                                    <td>@item.Date.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <div style="font-weight:600;">@item.User?.FullName</div>
                                        <div class="text-muted" style="font-size:12px;">@item.User?.EmployeeCode</div>
                                    </td>
                                    <td>@(item.User?.Department?.Name ?? "--")</td>
                                    <td>@(item.CheckIn?.ToString("HH:mm") ?? "--:--")</td>
                                    <td>@(item.CheckOut?.ToString("HH:mm") ?? "--:--")</td>
                                    <td>@(item.WorkHours > 0 ? $"{item.WorkHours:0.##}h" : "--")</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.Notes) ? "--" : item.Notes)</td>
                                    <td>
                                        <a class="btn btn-sm btn-outline" href="@Url.Action("TimekeepingDetails", new { id = item.Id })">Chi tiết</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted" style="padding:32px;">Không có dữ liệu chấm công phù hợp bộ lọc hiện tại.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="glass-card mb-24">
            <div class="card-header">
                <h3><i class="bi bi-search"></i> Tìm kiếm nhân viên</h3>
            </div>
            <div class="card-body">
                <form method="get" asp-action="Index">
                    <input type="hidden" name="tab" value="users" />
                    <div class="form-row">
                        <div class="col-4">
                            <label class="form-label">Từ khóa</label>
                            <input type="text" class="form-control" name="employeeSearch" value="@Model.EmployeeSearch" placeholder="Tên, email, mã NV" />
                        </div>
                        <div class="col-4">
                            <label class="form-label">Phòng ban</label>
                            <select class="form-control" name="employeeDepartmentId">
                                <option value="">Tất cả phòng ban</option>
                                @foreach (var dept in Model.Departments.OrderBy(d => d.Name))
                                {
                                    <option value="@dept.Id" selected="@(Model.EmployeeDepartmentId == dept.Id)">@dept.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="d-flex gap-12 flex-wrap" style="margin-top:16px;">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Tìm kiếm</button>
                        <a href="@Url.Action("Index", new { tab = "users" })" class="btn btn-outline">Đặt lại</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="glass-card">
            <div class="card-header d-flex justify-between align-center">
                <h3><i class="bi bi-people-fill"></i> Quản lý nhân viên</h3>
                <span class="text-muted">@Model.Users.Count nhân viên</span>
            </div>
            <div class="card-body" style="padding:0; overflow-x:auto;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Mã NV</th>
                            <th>Họ Tên</th>
                            <th>Chức vụ</th>
                            <th>Phòng ban</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Users.Any())
                        {
                            @foreach (var e in Model.Users)
                            {
                                <tr>
                                    <td>@e.EmployeeCode</td>
                                    <td>
                                        <div style="font-weight:700;">@e.FullName</div>
                                        <div class="text-muted" style="font-size:12px;">@e.Email</div>
                                    </td>
                                    <td>@(e.Position?.Name ?? e.JobTitle?.Name ?? "--")</td>
                                    <td>@(e.Department?.Name ?? "--")</td>
                                    <td>
                                        <a href="@Url.Action("EmployeeDetails", new { id = e.Id })">Chi tiết</a> |
                                        <a href="@Url.Action("EditUser", new { id = e.Id })">Sửa</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted" style="padding:32px;">Không tìm thấy nhân viên phù hợp.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
