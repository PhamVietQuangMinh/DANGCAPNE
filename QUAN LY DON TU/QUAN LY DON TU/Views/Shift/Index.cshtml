@model List<DANGCAPNE.Models.Timekeeping.UserShift>
@{
    ViewData["Title"] = "Lịch biểu & ca làm";
}

<div class="page-content">
    <div class="glass-card">
        <div class="card-header">
            <h3><i class="bi bi-calendar3 text-primary"></i> Lịch biểu & ca làm</h3>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-calendar2-week"></i>
                    <p>Hiện chưa có ca làm nào được phân cho bạn.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Từ ngày</th>
                                <th>Đến ngày</th>
                                <th>Ca làm</th>
                                <th>Giờ bắt đầu</th>
                                <th>Giờ kết thúc</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.EffectiveDate.ToString("dd/MM/yyyy")</td>
                                    <td>@(item.EndDate?.ToString("dd/MM/yyyy") ?? "Hiện tại")</td>
                                    <td>@(item.Shift?.Name ?? "Chưa gán")</td>
                                    <td>@(item.Shift?.StartTime.ToString(@"hh\:mm") ?? "--:--")</td>
                                    <td>@(item.Shift?.EndTime.ToString(@"hh\:mm") ?? "--:--")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
