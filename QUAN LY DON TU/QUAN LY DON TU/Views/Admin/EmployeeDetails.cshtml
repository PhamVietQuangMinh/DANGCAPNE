@model DANGCAPNE.ViewModels.AdminEmployeeDetailViewModel
@{
    ViewData["Title"] = "Chi tiết nhân viên";
}

<div class="page-content">
    <div class="d-flex justify-between align-center mb-24" style="gap:16px; flex-wrap:wrap;">
        <div>
            <h2 style="margin:0; font-size:28px; font-weight:800;">Chi tiết nhân viên</h2>
            <p class="text-muted" style="margin-top:6px;">Hiển thị thông tin nhân viên và lịch sử chấm công lấy từ cơ sở dữ liệu trên server.</p>
        </div>
        <div class="d-flex gap-12 flex-wrap">
            <a href="@Url.Action("EditUser", new { id = Model.Employee.Id })" class="btn btn-primary">Chỉnh sửa</a>
            <a href="@Url.Action("Index", new { tab = "users" })" class="btn btn-outline">Quay lại danh sách</a>
        </div>
    </div>

    <div class="form-row">
        <div class="col-7">
            <div class="glass-card mb-24">
                <div class="card-header">
                    <h3><i class="bi bi-person-vcard"></i> Thông tin nhân viên</h3>
                </div>
                <div class="card-body">
                    <dl class="row" style="margin:0;">
                        <dt class="col-sm-3">Mã NV</dt>
                        <dd class="col-sm-9">@Model.Employee.EmployeeCode</dd>

                        <dt class="col-sm-3">Họ Tên</dt>
                        <dd class="col-sm-9">@Model.Employee.FullName</dd>

                        <dt class="col-sm-3">Email</dt>
                        <dd class="col-sm-9">@Model.Employee.Email</dd>

                        <dt class="col-sm-3">Số điện thoại</dt>
                        <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Employee.Phone) ? "--" : Model.Employee.Phone)</dd>

                        <dt class="col-sm-3">Phòng ban</dt>
                        <dd class="col-sm-9">@(Model.Employee.Department?.Name ?? "--")</dd>

                        <dt class="col-sm-3">Chức vụ</dt>
                        <dd class="col-sm-9">@(Model.Employee.Position?.Name ?? Model.Employee.JobTitle?.Name ?? "--")</dd>

                        <dt class="col-sm-3">Ngày vào làm</dt>
                        <dd class="col-sm-9">@Model.Employee.HireDate.ToString("dd/MM/yyyy")</dd>
                    </dl>
                </div>
            </div>

            <div class="glass-card">
                <div class="card-header">
                    <h3><i class="bi bi-clock-history"></i> Lịch sử chấm công gần đây</h3>
                </div>
                <div class="card-body" style="padding:0; overflow-x:auto;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Ngày</th>
                                <th>Giờ vào</th>
                                <th>Giờ ra</th>
                                <th>Giờ công</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentTimesheets.Any())
                            {
                                @foreach (var item in Model.RecentTimesheets)
                                {
                                    <tr>
                                        <td>@item.Date.ToString("dd/MM/yyyy")</td>
                                        <td>@(item.CheckIn?.ToString("HH:mm") ?? "--:--")</td>
                                        <td>@(item.CheckOut?.ToString("HH:mm") ?? "--:--")</td>
                                        <td>@(item.WorkHours > 0 ? $"{item.WorkHours:0.##}h" : "--")</td>
                                        <td>@item.Status</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted" style="padding:24px;">Chưa có dữ liệu chấm công.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-5">
            <div class="glass-card">
                <div class="card-header">
                    <h3><i class="bi bi-info-circle"></i> Ghi chú</h3>
                </div>
                <div class="card-body">
                    <ul style="margin:0; padding-left:18px; color:#475569;">
                        <li>Dữ liệu nhân viên trên trang này được truy vấn trực tiếp từ database qua `ApplicationDbContext`.</li>
                        <li>Phần quản lý tài khoản như khóa, reset mật khẩu, vô hiệu hóa đã được gỡ khỏi giao diện admin này.</li>
                        <li>Bạn vẫn có thể cập nhật thông tin nhân viên cơ bản bằng nút <strong>Chỉnh sửa</strong>.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
